# Local development environment variables.
# Copy to .env and fill in. In deployed environments, these come from AWS Secrets Manager
# (see infra/cdk/lib/secrets-stack.ts) and are injected by the ECS task definition.

# --- Database ---
# Matches docker-compose.yml defaults. Override for cloud connections.
DATABASE_URL=postgresql://capiro:capiro@localhost:5432/capiro?schema=public

# --- API ---
API_PORT=4000
API_BIND_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# --- Clerk (https://dashboard.clerk.com -> API Keys) ---
# Backend SDK uses CLERK_SECRET_KEY for JWT verification + Backend API calls.
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Used by the web app (Vite). Public, safe to ship to the browser.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Webhook signing secret from Clerk dashboard -> Webhooks -> your endpoint.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_REPLACE_ME

# Pin the JWT issuer so verifyToken rejects tokens minted by any other Clerk
# instance. For Capiro production this is https://clerk.app.capiro.ai.
CLERK_JWT_ISSUER=https://clerk.app.capiro.ai

# --- Web ---
VITE_API_BASE_URL=http://localhost:4000

# --- Engagement crypto + OAuth (Microsoft 365) ---
# 32-byte AES-256-GCM key (base64 or hex) for meeting notes at-rest encryption.
NOTES_ENCRYPTION_KEY=
NOTES_ENCRYPTION_KEY_VERSION=v1

# 32-byte AES-256-GCM key (base64 or hex) for OAuth tokens at rest. MUST be
# different from NOTES_ENCRYPTION_KEY so a compromise of either side is contained.
OAUTH_TOKEN_ENCRYPTION_KEY=
OAUTH_TOKEN_ENCRYPTION_KEY_VERSION=v1

# 32+ byte secret used to HMAC-sign the OAuth `state` parameter so the
# /callback can prove the connection_id came from a /start it issued.
OAUTH_STATE_SECRET=

# Microsoft 365 Graph OAuth (capiro-outlook app registration). The capiro.ai
# tenant blocks client secrets, so we authenticate via certificate. The PEM
# private key may be set directly (multi-line) or as base64-encoded PEM.
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CERT_THUMBPRINT=
MICROSOFT_CERT_PRIVATE_KEY=
# Override only when running locally. Default is the prod redirect.
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/engagement/integrations/microsoft/callback
# Path the user lands on after the callback completes.
MICROSOFT_OAUTH_SUCCESS_REDIRECT=/settings/integrations
