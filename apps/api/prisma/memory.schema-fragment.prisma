// ============================================================================
// INSTITUTIONAL MEMORY — schema fragment (APPEND to apps/api/prisma/schema.prisma)
// ============================================================================
// Status: AUTHORED, NOT APPLIED. Per Neo's DB guardrail, no migration has been
// run against any database. To adopt:
//   1. Paste these two models into apps/api/prisma/schema.prisma.
//   2. Add the back-relations to Tenant and Client (see comments below).
//   3. Generate the migration:  pnpm prisma migrate dev --name institutional_memory --create-only
//   4. Replace the generated SQL with migration.sql in this folder (adds RLS).
//   5. Review, then apply in staging/devbox BEFORE prod.
//
// Design (plan §0.5): the MemoryItem row is the CANONICAL store the AI queries.
// The markdown vault is a projection rendered from these rows. Sections are
// stored as JSON so each section's single writer (engine|human) is preserved
// losslessly through the render/parse round-trip.
//
// Scoping: tenant_id NOT NULL, RLS-FORCED via the existing app.current_tenant
// GUC + current_tenant_id()/rls_bypass() helpers (migration 20260501000000).
// Memory items are ROWS scoped by the SAME controls as the rest of the product
// — they do not bypass column-level controls because they ARE columns.

/// Canonical institutional-memory item. Projected to an Obsidian-format
/// markdown file in the vault; consumed structurally by the AI / Intelligence
/// Center. Facts live in the referenced entity row (entityId); this holds the
/// interpretation/narrative around them.
model MemoryItem {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  /// Client scope when applicable; NULL for firm-level/unscoped items.
  clientId      String?  @map("client_id") @db.Uuid
  /// Owning user; REQUIRED when visibility='user' (private items). Enforced by
  /// the CHECK constraint in migration.sql.
  ownerUserId   String?  @map("owner_user_id") @db.Uuid
  /// MemoryItemType discriminator (firm-soul, client-soul, thread, ...).
  type          String   @db.VarChar(32)
  /// 'tenant' (firm-shared) | 'user' (private to owner).
  visibility    String   @default("tenant") @db.VarChar(16)
  /// FK-by-value to the authoritative Postgres entity row this item narrates.
  /// Not a hard FK because targets span many tables (client, bill, meeting...).
  entityId      String?  @map("entity_id") @db.Uuid
  /// Vault slug + wikilink target. Unique within (tenant, type).
  slug          String
  title         String
  aliases       String[] @default([])
  tags          String[] @default([])
  /// MemorySource: graph-email | meri | manual | meeting-service | ingest.
  source        String   @db.VarChar(24)
  sourceRef     String?  @map("source_ref")
  /// 'human' | 'ingest@<version>' — drives merge ownership.
  provenance    String   @default("human") @db.VarChar(32)
  /// MemorySection[] as JSON: [{key, heading, owner:'engine'|'human', body}].
  /// Single-writer-per-section is the merge model (plan §0.5 concern 2).
  sections      Json     @default("[]") @map("sections_jsonb")
  schemaVersion Int      @default(1) @map("schema_version")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  edges  MemoryEdge[]

  @@unique([tenantId, type, slug], map: "memory_items_tenant_type_slug_unique")
  @@index([tenantId, clientId], map: "memory_items_tenant_client_idx")
  @@index([tenantId, visibility, ownerUserId], map: "memory_items_tenant_visibility_owner_idx")
  @@index([tenantId, type], map: "memory_items_tenant_type_idx")
  @@index([entityId], map: "memory_items_entity_idx")
  @@map("memory_items")
}

/// Directed graph edge derived from a `[[type:slug]]` wikilink in an item's
/// markdown (criterion #5). Merged with DB FKs to feed the Intelligence Center
/// knowledge-graph tab (Phase 3). Re-derived on every save, so it is a cache.
model MemoryEdge {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  srcItemId String   @map("src_item_id") @db.Uuid
  /// Link relation; 'mentions' for wikilinks.
  relation  String   @default("mentions") @db.VarChar(32)
  dstType   String   @map("dst_type") @db.VarChar(32)
  dstSlug   String   @map("dst_slug")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  src    MemoryItem @relation(fields: [srcItemId], references: [id], onDelete: Cascade)

  @@unique([srcItemId, relation, dstType, dstSlug], map: "memory_edges_unique")
  @@index([tenantId, dstType, dstSlug], map: "memory_edges_tenant_dst_idx")
  @@map("memory_edges")
}

