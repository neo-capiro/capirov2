  lastSyncedAt      DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@index([name], map: "lda_registrant_name_idx")
  @@map("lda_registrant")
}

model LdaLobbyist {
  // 88K registered lobbyists extracted from LDA filings.
  id               Int      @id
  firstName        String   @default("") @map("first_name")
  lastName         String   @default("") @map("last_name")
  prefix           String?
  suffix           String?
  coveredPositions Json     @default("[]") @map("covered_positions")
  registrantIds    Int[]    @default([]) @map("registrant_ids")
  activeYears      Int[]    @default([]) @map("active_years")
  lastSyncedAt     DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@index([lastName, firstName], map: "lda_lobbyist_name_idx")
  @@map("lda_lobbyist")
}

model LdaContribution {
  // 192K contribution reports (LD-203 filings).
  id                String    @id @default(uuid()) @db.Uuid
  filingUuid        String    @unique @map("filing_uuid")
  filingType        String    @map("filing_type")
  filingYear        Int       @map("filing_year")
  filingPeriod      String?   @map("filing_period")
  filerType         String    @default("registrant") @map("filer_type")
  dtPosted          DateTime? @map("dt_posted") @db.Timestamptz(6)
  registrantId      Int?      @map("registrant_id")
  registrantName    String?   @map("registrant_name")
  lobbyistId        Int?      @map("lobbyist_id")
  lobbyistName      String?   @map("lobbyist_name")
  noContributions   Boolean   @default(false) @map("no_contributions")
  pacs              Json      @default("[]") @map("pacs")
  contributionItems Json      @default("[]") @map("contribution_items")
  lastSyncedAt      DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@index([filingYear], map: "lda_contribution_year_idx")
  @@index([registrantId], map: "lda_contribution_registrant_id_idx")
  @@map("lda_contribution")
}

model LdaIssueCode {
  // 79 LDA issue code reference records with 5-year aggregates.
  code            String   @id
  name            String
  totalFilings5y  Int      @default(0) @map("total_filings_5y")
  totalSpending5y Decimal? @map("total_spending_5y") @db.Decimal(18, 2)
  quarterlyTrend  Json     @default("[]") @map("quarterly_trend")
  lastSyncedAt    DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@map("lda_issue_code")
}

model LdaGovernmentEntity {
  // 257 federal government entity reference records.
  id             Int      @id
  name           String
  totalFilings5y Int      @default(0) @map("total_filings_5y")
  lastSyncedAt   DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@map("lda_government_entity")
}

// ─────────────────────────────────────────────────────────────────────────
// FEC Campaign Finance Data
//
// GLOBAL tables, shared across all tenants. No tenant_id, no RLS.
// Populated by apps/api/scripts/sync-fec.ts.
// Source: https://api.open.fec.gov/v1/, FEC campaign finance data.
// ─────────────────────────────────────────────────────────────────────────

model FecCommittee {
  // PACs and campaign committees from FEC API.
  id                 String   @id // committee_id like C00835926
  name               String
  committeeType      String?  @map("committee_type")
  designation        String?
  party              String?
  state              String?
  treasurerName      String?  @map("treasurer_name")
  totalReceipts      Decimal? @map("total_receipts") @db.Decimal(18, 2)
  totalDisbursements Decimal? @map("total_disbursements") @db.Decimal(18, 2)
  cashOnHand         Decimal? @map("cash_on_hand") @db.Decimal(18, 2)
  cycles             Int[]    @default([])
  lastSyncedAt       DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@index([name], map: "fec_committee_name_idx")
  @@map("fec_committee")
}

model FecContribution {
  // Individual/PAC contributions to candidates (Schedule A).
  id                    String    @id @default(uuid()) @db.Uuid
  committeeId           String    @map("committee_id")
  committeeName         String?   @map("committee_name")
  candidateId           String?   @map("candidate_id")
  candidateName         String?   @map("candidate_name")
  contributorName       String?   @map("contributor_name")
  contributorEmployer   String?   @map("contributor_employer")
  contributorOccupation String?   @map("contributor_occupation")
  amount                Decimal   @db.Decimal(18, 2)
  contributionDate      DateTime? @map("contribution_date") @db.Date
  receiptType           String?   @map("receipt_type")
  memoText              String?   @map("memo_text")
  state                 String?
  cycle                 Int
  lastSyncedAt          DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@unique([committeeId, candidateName, contributorEmployer, amount, cycle], map: "fec_contribution_dedup_key")
  @@index([committeeId], map: "fec_contribution_committee_id_idx")
  @@index([candidateName], map: "fec_contribution_candidate_name_idx")
  @@index([contributorEmployer], map: "fec_contribution_employer_idx")
  @@index([cycle], map: "fec_contribution_cycle_idx")
  @@map("fec_contribution")
}

model FecPacContribution {
  // Schedule B — disbursements BY a committee (PAC) TO candidates/committees.
  // This is the organization's OWN PAC giving — legally distinct from the
  // individual employer-linked contributions in FecContribution (Schedule A).
  // GLOBAL table (no tenant_id, no RLS); attributed to a client via a confirmed
  // ClientIntelMapping(source='fec_committee') linking client -> committeeId.
  id                   String    @id @default(uuid()) @db.Uuid
  committeeId          String    @map("committee_id") // the giving PAC committee
  committeeName        String?   @map("committee_name")
  recipientName        String?   @map("recipient_name") // candidate/committee receiving
  recipientCommitteeId String?   @map("recipient_committee_id")
  candidateId          String?   @map("candidate_id")
  candidateName        String?   @map("candidate_name")
  amount               Decimal   @db.Decimal(18, 2)
  disbursementDate     DateTime? @map("disbursement_date") @db.Date
  disbursementType     String?   @map("disbursement_type")
  memoText             String?   @map("memo_text")
  cycle                Int
  lastSyncedAt         DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@unique([committeeId, recipientName, amount, disbursementDate, cycle], map: "fec_pac_contribution_dedup_key")
  @@index([committeeId], map: "fec_pac_contribution_committee_id_idx")
  @@index([candidateName], map: "fec_pac_contribution_candidate_name_idx")
  @@index([cycle], map: "fec_pac_contribution_cycle_idx")
  @@map("fec_pac_contribution")
}

// ─────────────────────────────────────────────────────────────────────────
// Congress.gov Legislative Data
//
// GLOBAL tables, shared across all tenants. No tenant_id, no RLS.
// Populated by apps/api/scripts/sync-congress.ts.
// Source: https://api.congress.gov/v3/, Congress.gov API.
// ─────────────────────────────────────────────────────────────────────────

model CongressBill {
  // Bills from Congress.gov (118th and 119th Congress).
  id               String    @id // e.g. "119-hr-1234"
  congress         Int
  billType         String    @map("bill_type")
  billNumber       String    @map("bill_number")
  title            String
  introducedDate   DateTime? @map("introduced_date") @db.Date
  sponsorName      String?   @map("sponsor_name")
  sponsorState     String?   @map("sponsor_state")
  sponsorParty     String?   @map("sponsor_party")
  latestActionText String?   @map("latest_action_text")
  latestActionDate DateTime? @map("latest_action_date") @db.Date
  policyArea       String?   @map("policy_area")
  subjects         String[]  @default([])
  peCodes          String[]  @default([]) @map("pe_codes")
  committees       Json      @default("[]")
  cosponsorsCount  Int       @default(0) @map("cosponsors_count")
  originChamber    String?   @map("origin_chamber")
  updateDate       DateTime? @map("update_date") @db.Timestamptz(6)
  url              String?
  lastSyncedAt     DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  actions       CongressBillAction[]
  committeeRefs CongressBillCommittee[]
  subjectRefs   CongressBillSubject[]

  @@index([congress], map: "congress_bill_congress_idx")
  @@index([policyArea], map: "congress_bill_policy_area_idx")
  @@index([peCodes], map: "congress_bill_pe_codes_gin_idx", type: Gin)
  @@map("congress_bill")
}

/// Cached full bill text fetched from GovInfo, used by the bill PE-code extractor.
/// Global table — no tenant_id, no RLS. One row per bill (bill_id unique).
model BillText {
  id          String   @id @default(uuid()) @db.Uuid
  billId      String   @unique @map("bill_id")
  sourceUrl   String?  @map("source_url")
  textContent String   @map("text_content") @db.Text
  fetchedAt   DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)

  @@map("bill_text")
}

// ─────────────────────────────────────────────────────────────────────────
// Expanded Congress bill data (normalized)
// GLOBAL tables, no tenant_id, no RLS.
// ─────────────────────────────────────────────────────────────────────────

model CongressBillAction {
  id      String       @id @default(uuid())
  billId  String       @map("bill_id")
  date    DateTime
  text    String       @db.Text
  type    String?
  chamber String?
  bill    CongressBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId, date])
  @@map("congress_bill_action")
}

model CongressBillCommittee {
  id            String       @id @default(uuid())
  billId        String       @map("bill_id")
  committeeName String       @map("committee_name")
  committeeCode String?      @map("committee_code")
  chamber       String?
  bill          CongressBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([committeeCode])
  @@map("congress_bill_committee")
}

model CongressBillSubject {
  id     String       @id @default(uuid())
  billId String       @map("bill_id")
  name   String
  bill   CongressBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([name])
  @@map("congress_bill_subject")
}

// ─────────────────────────────────────────────────────────────────────────
// Program Element Intelligence (DoD PE watch)
//
// GLOBAL tables, shared across all tenants. No tenant_id, no RLS.
// Populated by PE Watch sync jobs.
// ─────────────────────────────────────────────────────────────────────────

model ProgramElement {
  peCode             String   @id @map("pe_code") @db.VarChar(16)
  service            String?
  serviceCode        String?  @map("service_code")
  appropriationType  String?  @map("appropriation_type")
  budgetActivity     String?  @map("budget_activity")
  budgetActivityName String?  @map("budget_activity_name")
  lineNumber         String?  @map("line_number")
  title              String
  description        String?  @db.Text
  acatLevel          String?  @map("acat_level")
  programOfRecord    String?  @map("program_of_record")
  status             String?
  rDocUrl            String?  @map("r_doc_url")
  pDocUrl            String?  @map("p_doc_url")
  oDocUrl            String?  @map("o_doc_url")
  raw                Json     @default("{}") @map("raw_jsonb")
  source             String
  sourceConfidence   Float?   @map("source_confidence")
  firstSeenFy        Int?     @map("first_seen_fy")
  lastSyncedAt       DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)
  // Soft-retire marker. Set by reconcile-stale-pes for PEs that exist ONLY because
  // of the old stanford spreadsheet (source='stanford_pe_directory_jan2026') and
  // carry no live signal (no linked person/award/bill/watch/year). Reads exclude
  // retiredAt IS NOT NULL by default. Reversible. NOT a hard delete — watches /
  // awards / bills reference pe_code with no FK, so we never DELETE the row.
  retiredAt          DateTime? @map("retired_at") @db.Timestamptz(6)
  retiredReason      String?   @map("retired_reason")

  years                   ProgramElementYear[]
  milestones              ProgramElementMilestone[]
  yearSourceValues        ProgramElementYearSourceValue[]
  watches                 ProgramElementWatch[]
  conferenceProbabilities ConferenceProbability[]
  sources                 ProgramElementSource[]
  projects                ProgramElementProject[]

  @@index([serviceCode], map: "program_element_service_code_idx")
  @@index([appropriationType], map: "program_element_appropriation_type_idx")
  @@index([status], map: "program_element_status_idx")
  @@index([retiredAt], map: "program_element_retired_at_idx")
  @@map("program_element")
}

// Page-level provenance for a Program Element, sourced from DoD Comptroller
// budget justification books (J-books). Each row is one citation users can open
// at the exact page (deep link: `${sourceUrl}#page=${pageNumber}`) and screenshot
// the original exhibit. Mirrors AcquisitionPersonnelSource. Global table (no
// tenant_id / RLS): J-book data is public-domain and read-only via API.
model ProgramElementSource {
  id          String   @id @default(uuid()) @db.Uuid
  peCode      String   @map("pe_code") @db.VarChar(16)
  docType     String   @map("doc_type") @db.VarChar(8) // R | P | O
  exhibitType String?  @map("exhibit_type") @db.VarChar(16) // R-1 | R-2 | R-2A | P-1 | P-40
  fy          Int?
  sourceUrl   String   @map("source_url")
  pageNumber  Int?     @map("page_number")
  pageEnd     Int?     @map("page_end")
  snippet     String?  @db.Text
  publisher   String?  @db.VarChar(64) // e.g. "DoD Comptroller"
  confidence  Float    @default(0.9)
  metadata    Json     @default("{}") @map("metadata_jsonb")
  observedAt  DateTime @default(now()) @map("observed_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  programElement ProgramElement @relation(fields: [peCode], references: [peCode], onDelete: Cascade)

  @@unique([peCode, docType, sourceUrl, pageNumber], map: "program_element_source_pe_doc_url_page_key")
  @@index([peCode], map: "program_element_source_pe_code_idx")
  @@index([peCode, fy], map: "program_element_source_pe_fy_idx")
  @@index([docType], map: "program_element_source_doc_type_idx")
  @@map("program_element_source")
}

// Project / sub-element within a Program Element, sourced from Service RDT&E
// Justification Book R-2A exhibits (e.g. PE 0601102A -> projects AA1, AA2, ...).
// Each project carries its own mission narrative and a page-level citation back to
// the originating exhibit. Global table (no tenant_id / RLS): J-book data is
// public-domain and read-only via API. Mirrors ProgramElementSource conventions.
model ProgramElementProject {
  id             String   @id @default(uuid()) @db.Uuid
  peCode         String   @map("pe_code") @db.VarChar(16)
  projectCode    String   @map("project_code") @db.VarChar(8)
  title          String
  mission        String?  @db.Text
  budgetActivity String?  @map("budget_activity")
  fy             Int?
  sourceUrl      String?  @map("source_url")
  pageNumber     Int?     @map("page_number")
  source         String   @default("comptroller_jbook_r2a")
  confidence     Float    @default(0.9)
  metadata       Json     @default("{}") @map("metadata_jsonb")
  firstSeenAt    DateTime @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSyncedAt   DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  programElement ProgramElement @relation(fields: [peCode], references: [peCode], onDelete: Cascade)

  @@unique([peCode, projectCode], map: "program_element_project_pe_code_project_key")
  @@index([peCode], map: "program_element_project_pe_code_idx")
  @@map("program_element_project")
}

model ProgramElementYear {
  id           String   @id @default(uuid()) @db.Uuid
  peCode       String   @map("pe_code") @db.VarChar(16)
  fy           Int
  request      Decimal? @db.Decimal(14, 2)
  hascMark     Decimal? @map("hasc_mark") @db.Decimal(14, 2)
  sascMark     Decimal? @map("sasc_mark") @db.Decimal(14, 2)
  hacDMark     Decimal? @map("hac_d_mark") @db.Decimal(14, 2)
  sacDMark     Decimal? @map("sac_d_mark") @db.Decimal(14, 2)
  conference   Decimal? @db.Decimal(14, 2)
  enacted      Decimal? @db.Decimal(14, 2)
  reprogrammed Decimal? @db.Decimal(14, 2)
  executed     Decimal? @db.Decimal(14, 2)
  notes        String?  @db.Text
  rDocSection  String?  @map("r_doc_section")
  raw          Json     @default("{}") @map("raw_jsonb")
  lastSyncedAt DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  programElement ProgramElement @relation(fields: [peCode], references: [peCode], onDelete: Cascade)

  @@unique([peCode, fy], map: "program_element_year_pe_code_fy_key")
  @@index([fy], map: "program_element_year_fy_idx")
  @@map("program_element_year")
}

model ProgramElementMilestone {
  id            String    @id @default(uuid()) @db.Uuid
  peCode        String    @map("pe_code") @db.VarChar(16)
  milestoneType String    @map("milestone_type")
  plannedDate   DateTime? @map("planned_date") @db.Date
  actualDate    DateTime? @map("actual_date") @db.Date
  status        String?
  source        String
  notes         String?   @db.Text
  lastSyncedAt  DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  programElement ProgramElement @relation(fields: [peCode], references: [peCode], onDelete: Cascade)

  @@unique([peCode, milestoneType], map: "program_element_milestone_pe_code_type_key")
  @@index([status], map: "program_element_milestone_status_idx")
  @@map("program_element_milestone")
}

model ProgramElementQuarantine {
  id            String   @id @default(uuid()) @db.Uuid
  rawRecord     Json     @map("raw_record")
  reason        String
  source        String
  quarantinedAt DateTime @default(now()) @map("quarantined_at") @db.Timestamptz(6)

  @@map("program_element_quarantine")
}

model ProgramElementYearSourceValue {
  id           String   @id @default(uuid()) @db.Uuid
  peCode       String   @map("pe_code") @db.VarChar(16)
  fy           Int
  fieldName    String   @map("field_name")
  source       String
  valueJsonb   Json     @default("null") @map("value_jsonb")
  // Per-field reconciliation values (Step 29 §4.1). value_decimal for numeric
  // marks/dollars, value_text for narrative fields. written_at mirrors recordedAt
  // for the reconciliation queue's naming.
  valueDecimal Decimal? @map("value_decimal") @db.Decimal(18, 2)
  valueText    String?  @map("value_text") @db.Text
  writtenAt    DateTime @default(now()) @map("written_at") @db.Timestamptz(6)
  isWinner     Boolean  @default(false) @map("is_winner")
  recordedAt   DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)

  programElement ProgramElement @relation(fields: [peCode], references: [peCode], onDelete: Cascade)

  @@index([peCode, fy, fieldName], map: "program_element_year_source_value_lookup_idx")
  @@index([peCode, fy, fieldName, isWinner], map: "program_element_year_source_value_winner_idx")
  @@map("program_element_year_source_value")
}

/// Cross-source reconciliation review queue (Step 29 §4.1). An entry is queued when
/// a lower-priority source conflicts with the canonical value by > 10% (non-enacted
/// fields) or by ANY amount on the enacted field. capiro_admin resolves entries.
model ReconciliationReviewQueue {
  id                String    @id @default(uuid()) @db.Uuid
  peCode            String    @map("pe_code") @db.VarChar(16)
  fy                Int
  fieldName         String    @map("field_name")
  currentValue      String?   @map("current_value")
  conflictingSource String    @map("conflicting_source")
  conflictingValue  String?   @map("conflicting_value")
  deltaPct          Float?    @map("delta_pct")
  queuedAt          DateTime  @default(now()) @map("queued_at") @db.Timestamptz(6)
  status            String    @default("open") @db.VarChar(20)
  resolvedByUserId  String?   @map("resolved_by_user_id") @db.Uuid
  resolvedAt        DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolutionNotes   String?   @map("resolution_notes") @db.Text

  @@index([status, queuedAt(sort: Desc)], map: "reconciliation_review_queue_status_idx")
  @@index([peCode, fy], map: "reconciliation_review_queue_pe_fy_idx")
  @@map("reconciliation_review_queue")
}

model ProgramElementWatch {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  peCode    String   @map("pe_code") @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  programElement ProgramElement @relation(fields: [peCode], references: [peCode], onDelete: Cascade)

  @@unique([userId, peCode], map: "program_element_watch_user_pe_code_key")
  @@index([tenantId, peCode], map: "program_element_watch_tenant_pe_code_idx")
  @@map("program_element_watch")
}

model AcquisitionPersonnel {
  id               String   @id @default(uuid()) @db.Uuid
  fullName         String   @map("full_name")
  nameKey          String   @map("name_key")
  service          String?  @db.VarChar(8)
  organization     String?
  title            String?
  role             String?
  programOfRecord  String?  @map("program_of_record")
  pePrimary        String?  @map("pe_primary") @db.VarChar(16)
  peSecondary      String[] @default([]) @map("pe_secondary")
  emailDomain      String?  @map("email_domain")
  publicProfileUrl String?  @map("public_profile_url")
  confidence       Float    @default(0.5)
  status           String   @default("active") @db.VarChar(16)
  // Soft-supersede marker. Set by reconcile-personnel-supersede when a person's
  // only provenance is a deprecated one-time directory load (e.g. the old
  // stanford_dow_* spreadsheet) and no current source re-asserts them. Reads
  // exclude supersededAt IS NOT NULL by default. Reversible (set back to null).
  // Distinct from status='departed', which is a real-world departure signal.
  supersededAt     DateTime? @map("superseded_at") @db.Timestamptz(6)
  supersededReason String?   @map("superseded_reason")
  firstSeenAt      DateTime @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt       DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  metadata         Json     @default("{}") @map("metadata_jsonb")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  sources AcquisitionPersonnelSource[]

  @@index([pePrimary], map: "acquisition_personnel_pe_primary_idx")
  @@index([nameKey], map: "acquisition_personnel_name_key_idx")
  @@index([service, organization], map: "acquisition_personnel_service_org_idx")
  @@index([status], map: "acquisition_personnel_status_idx")
  @@index([supersededAt], map: "acquisition_personnel_superseded_at_idx")
  @@map("acquisition_personnel")
}

model AcquisitionPersonnelSource {
  id         String   @id @default(uuid()) @db.Uuid
  personId   String   @map("person_id") @db.Uuid
  source     String   @db.VarChar(64)
  sourceUrl  String?  @map("source_url")
  snippet    String?  @db.Text
  observedAt DateTime @map("observed_at") @db.Timestamptz(6)
  confidence Float
  metadata   Json     @default("{}") @map("metadata_jsonb")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

