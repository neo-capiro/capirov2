  totalFilings      Int      @default(0) @map("total_filings")
  totalClients      Int      @default(0) @map("total_clients")
  lastSyncedAt      DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@index([name], map: "lda_registrant_name_idx")
