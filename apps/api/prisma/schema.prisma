  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, clientId, createdAt(sort: Desc)])
  @@map("clio_proactive_alerts")
}

