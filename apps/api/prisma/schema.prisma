  @@map("lobby_issue_ref")
}

model LobbyTrendingTopic {
  // Top words and trending words mined from filing descriptions —
  // injected into AI doc-gen prompts as "current Washington context".
  id           String   @id @default(uuid()) @db.Uuid
  word         String   @unique
  latestCount  Int      @map("latest_count")
  avgPrior     Float?   @map("avg_prior")
  growthPct    Float?   @map("growth_pct")
  kind         String   @default("trending") // trending | top | bill
  lastSyncedAt DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

