// ─────────────────────────────────────────────────────────────────────────
// Manually tracked bills (user-pinned legislation per client).
// TENANT-scoped with RLS. Distinct from the derived "relevant" bills the
// Issue-Bill Linker surfaces by embedding similarity: this records an explicit
// human decision to follow a specific congress_bill for a client, so it
// survives re-matching and always pins to the top of the pipeline kanban.
// ─────────────────────────────────────────────────────────────────────────

model TrackedBill {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  billId    String   @map("bill_id") // FK-ish to congress_bill.id, e.g. "119-hr-1234"
  note      String?  @db.Text
  createdBy String?  @map("created_by") // clerk user id of whoever pinned it
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([clientId, billId])
  @@index([tenantId])
  @@index([clientId])
  @@index([billId])
  @@map("tracked_bill")
}

// ─────────────────────────────────────────────────────────────────────────
// Per-user worklist state for client-profile "Top alerts".
// TENANT-scoped with RLS (mirrors tracked_bill / engagement isolation).
// State is keyed by (user, client, alertId) — alertId is the stable composite
// the alerts builder emits ("comment:<docId>", "hearing:<id>", "bill:<billId>",
// "change:<id>", "award:<id>", "competitor:<filingId>", "comment_overdue:<docId>").
// Dismissed/snoozed alerts are filtered out server-side; acknowledged alerts are
// kept but flagged so the UI de-emphasizes them. Compute-on-read alerts have no
// durable row of their own, so this is the ONLY place their handled-state lives.
// ─────────────────────────────────────────────────────────────────────────

model AlertState {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  userId       String    @map("user_id") // clerk user id of whoever set the state
  clientId     String    @map("client_id") @db.Uuid
  alertId      String    @map("alert_id") // stable composite key from the alerts builder
  // 'acknowledged' | 'dismissed' | 'snoozed'
  state        String
  snoozedUntil DateTime? @map("snoozed_until") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, clientId, alertId])
  @@index([tenantId])
  @@index([clientId])
  @@index([userId])
  @@map("alert_state")
}

// ─────────────────────────────────────────────────────────────────────────
