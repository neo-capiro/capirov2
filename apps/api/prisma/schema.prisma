  filingType         String    @map("filing_type")
  filingYear         Int       @map("filing_year")
  filingPeriod       String?   @map("filing_period")
  income             Decimal?  @map("income") @db.Decimal(18, 2)
  expenses           Decimal?  @map("expenses") @db.Decimal(18, 2)
  dtPosted           DateTime? @map("dt_posted") @db.Timestamptz(6)
  registrantId       Int?      @map("registrant_id")
  registrantName     String    @default("") @map("registrant_name")
  clientId           Int?      @map("client_id")
  clientName         String    @default("") @map("client_name")
  clientState        String?   @map("client_state")
  clientCountry      String    @default("US") @map("client_country")
  clientDescription  String?   @map("client_description")
  issueCodes         String[]  @default([]) @map("issue_codes")
  governmentEntities Json      @default("[]") @map("government_entities")
  lobbyists          Json      @default("[]") @map("lobbyists")
  lobbyingActivities Json      @default("[]") @map("lobbying_activities")
  filingDocumentUrl  String?   @map("filing_document_url")
