  time          String? // "10:00 AM"
  location      String?
  type          String? // hearing, markup, meeting
  witnesses     String[] @default([])
  url           String?
  syncedAt      DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([date])
  @@index([committeeName, date])
  @@map("committee_hearing")
}

// ─────────────────────────────────────────────────────────────────────────
// SyncRun, observability for sync scripts
// GLOBAL table, no tenant_id, no RLS. One row per sync execution.
// ─────────────────────────────────────────────────────────────────────────

model SyncRun {
  id           String    @id @default(uuid()) @db.Uuid
  source       String
  startedAt    DateTime  @map("started_at") @db.Timestamptz(6)
  finishedAt   DateTime? @map("finished_at") @db.Timestamptz(6)
  rowsInserted Int       @default(0) @map("rows_inserted")
  rowsUpdated  Int       @default(0) @map("rows_updated")
  errorCount   Int       @default(0) @map("error_count")
  status       String    @default("running")
  errorMessage String?   @map("error_message")

  @@index([source, startedAt(sort: Desc)], map: "sync_run_source_started_at_idx")
  @@map("sync_run")
}

/// Global 24h response cache for GovInfo (api.data.gov) JSON API calls. Keyed by
/// the request URL (api_key stripped). Global table — no tenant_id, no RLS.
model GovInfoCache {
  id        String   @id @default(uuid()) @db.Uuid
  url       String   @unique
  response  Json     @map("response_jsonb")
  fetchedAt DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)

  @@index([fetchedAt], map: "govinfo_cache_fetched_at_idx")
  @@map("govinfo_cache")
}

/// Child procurement line items under a parent Program Element (P-Doc / Procurement
/// budget books). A parent PE (e.g. 0204134N F/A-18 Series) has FY totals on
/// program_element_year; its sub-line breakouts (kit codes, sub-quantities) live
/// here. Global table — no tenant_id, no RLS. Idempotent dedup on
/// (pe_code, line_description, fy).
model ProgramElementProcurementLine {
  id              String   @id @default(uuid()) @db.Uuid
  peCode          String   @map("pe_code") @db.VarChar(16)
  lineDescription String   @map("line_description")
  fy              Int
  quantity        Decimal? @db.Decimal(14, 2)
  dollars         Decimal? @db.Decimal(18, 2)
  unitCost        Decimal? @map("unit_cost") @db.Decimal(18, 2)
  source          String?
  sourceUrl       String?  @map("source_url")
  raw             Json     @default("{}") @map("raw_jsonb")
  lastSyncedAt    DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@unique([peCode, lineDescription, fy], map: "pe_procurement_line_dedup_key")
  @@index([peCode], map: "pe_procurement_line_pe_code_idx")
  @@index([fy], map: "pe_procurement_line_fy_idx")
  @@map("program_element_procurement_line")
}

/// Federal contract/assistance awards from USAspending.gov, enriched with PE
/// attribution. Global table (no tenant_id, no RLS). pe_code is nullable — an
/// award with no resolvable PE keeps pe_code NULL (NOT quarantined). The Step 6
/// /contractors endpoint reads contractor_name + amount + awarded_at + pe_code.
model FederalAward {
  id                             String    @id @default(uuid()) @db.Uuid
  // USAspending generated_unique_award_id — stable idempotency key.
  awardUniqueId                  String    @unique @map("award_unique_id")
  piid                           String?
  fain                           String?
  awardingAgency                 String?   @map("awarding_agency")
  awardingSubTier                String?   @map("awarding_sub_tier")
  contractorName                 String?   @map("contractor_name")
  recipientUei                   String?   @map("recipient_uei")
  amount                         Decimal?  @db.Decimal(18, 2)
  description                    String?   @db.Text
  peCode                         String?   @map("pe_code") @db.VarChar(16)
  // How pe_code was resolved, for provenance/auditing and honest UI labeling.
  // Null when pe_code is null. Values: 'description_regex' (legacy text match),
  // 'dod_acquisition_program' (linked via the contract's DoD acquisition / MDAP
  // code through the reviewed program_element_acquisition_program map). Lets the
  // contractor panel state HOW a contractor was tied to a PE rather than implying
  // a precision the source does not have.
  peCodeSource                   String?   @map("pe_code_source")
  // ── USAspending File C (financial_accounts_by_awards) funding crosswalk ──────────
  // Populated by enrich-award-pe-tas from /api/v2/awards/funding/. The Treasury
  // Account Symbol + Program Activity are the federal mechanism that ties an award
  // to the appropriation account / program activity it was funded from. We store the
  // dominant (largest-obligation) TAS+PA for display + the PE crosswalk. PE attribution
  // from TAS+PA is intentionally LOWER precision than the R-3 named-prime link (one
  // account/PA funds many PEs), so peCodeConfidence + peCodeCandidateCount make the
  // ambiguity explicit and the UI never implies a false 1:1.
  fundingTas                     String?   @map("funding_tas") // e.g. '057-3600' (federal_account) or full TAS label
  fundingTasTitle                String?   @map("funding_tas_title") // e.g. 'RDT&E, Air Force'
  programActivityCode            String?   @map("program_activity_code") // e.g. '0001'
  programActivityName            String?   @map("program_activity_name") // e.g. 'BASIC RESEARCH'
  fundingFy                      Int?      @map("funding_fy") // reporting fiscal year of the dominant File C row
  // 0..1 confidence of the pe_code attribution. 1.0 only when UEI-confirmed against an
  // R-3 named prime; ~0.5 when account+PA+FY resolve to a single PE; lower when ambiguous.
  peCodeConfidence               Float?    @map("pe_code_confidence")
  // How many distinct PEs the award's (account + program activity + FY) could map to.
  // 1 = unambiguous; >1 = the UI shows "funded via <account> (N programs)" not a single PE.
  peCodeCandidateCount           Int?      @map("pe_code_candidate_count")
  // When peCodeSource='uei_confirmed_r3_prime', the matched performer row id (audit trail).
  matchedPerformerId             String?   @map("matched_performer_id") @db.Uuid
  // DoD Major Defense Acquisition Program (MDAP) attribution straight off the
  // contract record (USAspending latest_transaction_contract_data). Always present
  // on contracts; '000'/'NONE' for services & non-program awards. This is the
  // zero-inference link between a contractor and a weapons program — e.g.
  // '198'/'F-35', '516'/'SSN 774'. PE attribution is derived from these via the
  // program_element_acquisition_program map, NOT fabricated.
  dodAcqProgramCode              String?   @map("dod_acq_program_code")
  dodAcqProgramName              String?   @map("dod_acq_program_name")
  // Place of performance (where the work happens) — primary signal for district
  // nexus. Recipient location (where the company is HQ'd) kept as a fallback.
  // Two-letter state + congressional-district number as text ('02', 'AL'); null
  // when USAspending omits it. Populated by sync-federal-award location fields.
  popState                       String?   @map("pop_state")
  popCongressionalDistrict       String?   @map("pop_congressional_district")
  recipientState                 String?   @map("recipient_state")
  recipientCongressionalDistrict String?   @map("recipient_congressional_district")
  actionDate                     DateTime? @map("action_date") @db.Date
  awardedAt                      DateTime? @map("awarded_at") @db.Timestamptz(6)
  raw                            Json      @default("{}") @map("raw_jsonb")
  lastSyncedAt                   DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@index([peCode], map: "federal_award_pe_code_idx")
  @@index([contractorName], map: "federal_award_contractor_name_idx")
  @@index([popState, popCongressionalDistrict], map: "federal_award_pop_district_idx")
  @@index([awardedAt], map: "federal_award_awarded_at_idx")
  @@index([actionDate], map: "federal_award_action_date_idx")
  @@index([dodAcqProgramCode], map: "federal_award_dod_acq_program_idx")
  @@map("federal_award")
}

/// Reviewed, EXPLICIT map from a DoD Major Defense Acquisition Program (MDAP)
/// code — as it appears on USAspending contract records
/// (latest_transaction_contract_data.dod_acquisition_program) — to a Program
/// Element. This is the defensible bridge that lets the PE contractor panel show
/// "who are the primes on this program" without inferring PE from coarse funding
/// accounts. Entries are curated/seeded (not machine-derived), so attribution is
/// auditable: e.g. ('198','F-35') -> the F-35-related PEs the program tracks.
/// A program maps to one-or-more PEs and a PE may be reached by one-or-more
/// program codes; the (acqProgramCode, peCode) pair is unique. Global table —
/// no tenant_id, no RLS (federal reference data, same as federal_award).
model ProgramElementAcquisitionProgram {
  id             String   @id @default(uuid()) @db.Uuid
  /// MDAP code exactly as USAspending emits it (e.g. '198', '516', 'SDN').
  acqProgramCode String   @map("acq_program_code")
  /// Human-readable program name for display/provenance (e.g. 'F-35').
  acqProgramName String?  @map("acq_program_name")
  peCode         String   @map("pe_code") @db.VarChar(16)
  /// Where this mapping came from (e.g. 'seed_curated_v1') for auditing.
  source         String   @default("seed_curated_v1")
  /// 0..1 reviewer confidence; the read path can threshold on this if needed.
  confidence     Float    @default(1.0)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSyncedAt   DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@unique([acqProgramCode, peCode], map: "pe_acq_program_code_pe_key")
  @@index([peCode], map: "pe_acq_program_pe_code_idx")
  @@index([acqProgramCode], map: "pe_acq_program_code_idx")
  @@map("program_element_acquisition_program")
}

/// Named prime contractor ("performing activity") for a Program Element, extracted
/// verbatim from the Service RDT&E Justification Book R-3 "Product Development" /
/// "Support" / "Management Services" cost-analysis tables (and embedded R-2A tables).
/// This is the zero-inference, government-STATED PE -> prime link: the exhibit names
/// the company, contract method/type, performing location, and total contract cost.
/// Each row carries page-level provenance so the contractor panel can deep-link to
/// the exact exhibit page ("per the Navy's own FY27 R-3 exhibit, page N"). Global
/// table (no tenant_id / RLS): J-book data is public-domain reference data, same as
/// program_element / federal_award. Loaded by the sync-jbook-performers verb from a
/// committed offline extraction artifact (scripts/__data__/jbook_performers_*.json);
/// no PDF/Python at runtime. Idempotent: unique on the natural performer key.
model ProgramElementPerformer {
  id                  String   @id @default(uuid()) @db.Uuid
  peCode              String   @map("pe_code") @db.VarChar(16)
  /// Company name exactly as printed in the exhibit (e.g. 'LOCKHEED MARTIN CORPORATION').
  performer           String
  /// Uppercased/punctuation-stripped name for joins/dedup (e.g. 'LOCKHEED MARTIN CORP').
  performerNormalized String   @map("performer_normalized")
  /// Performing location as printed (state code 'AL', 'Various', city, or country).
  /// NOT NULL ('' when absent) so the natural-key unique index is deterministic
  /// (Postgres treats NULLs as distinct, which would break idempotent upserts).
  location            String   @default("") @map("location")
  /// Contract method & type token ('SS/IDIQ','C/CPAF','MIPR',...). '' when blank/Various.
  contractMethod      String   @default("") @map("contract_method")
  /// Cost-category item label from the exhibit row (e.g. 'THAAD Development - Capability').
  costCategory        String   @default("") @map("cost_category")
  /// Total contract cost in $M as printed (TotalCost column). Null when not stated.
  totalCostM          Decimal? @map("total_cost_m") @db.Decimal(18, 3)
  /// R-3 table family this came from: 'product_development' | 'support' | 'management_services'.
  tableType           String?  @map("table_type")
  /// Project (R-2A) code/name when the table is under a specific project, else null.
  projectCode         String?  @map("project_code")
  projectName         String?  @map("project_name")
  fy                  Int
  sourceUrl           String   @map("source_url")
  pageNumber          Int      @map("page_number")
  /// Publishing component for provenance label (e.g. 'DoD Comptroller (Navy)').
  publisher           String?
  /// True when the performer is a real named company (has a legal suffix / not 'Various'/
  /// 'TBD'/government-internal MIPR). Lets the read path surface only real primes by default.
  isNamedCompany      Boolean  @default(true) @map("is_named_company")
  source              String   @default("comptroller_jbook_r3")
  confidence          Float    @default(0.95)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSyncedAt        DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)
  // Registry link (Step 0.1): the fingerprinted source file this performer row came from.
  sourceDocumentId    String?  @map("source_document_id") @db.Uuid

  programElement ProgramElement  @relation(fields: [peCode], references: [peCode], onDelete: Cascade)
  sourceDocument SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Natural key: same prime can appear under different cost categories / projects / methods.
  @@unique([peCode, performerNormalized, location, contractMethod, costCategory, fy], map: "program_element_performer_natural_key")
  @@index([peCode], map: "program_element_performer_pe_code_idx")
  @@index([performerNormalized], map: "program_element_performer_norm_idx")
  @@index([isNamedCompany], map: "program_element_performer_named_idx")
  @@index([sourceDocumentId], map: "program_element_performer_source_document_idx")
  @@map("program_element_performer")
}

// ─────────────────────────────────────────────────────────────────────────
// PROGRAM GRAPH (Step 2.1) — the canonical Program entity + alias dictionary +
// review-gated PE/project -> program matching. GLOBAL tables (no tenant_id / RLS):
// these describe public-domain federal programs, same as program_element /
// federal_award. PeProgramMatch is the graph's source of truth going forward;
// program_element_acquisition_program is kept for award attribution.
// ─────────────────────────────────────────────────────────────────────────

/// Canonical defense program (e.g. 'F-35', 'SSN 774'). One row per real-world
/// program-of-record. Seeded from program_element_acquisition_program MDAP codes
/// (seed-programs.ts) and grown by the matcher / human review. PE links live on
/// PeProgramMatch, not here.
model Program {
  id                 String   @id @default(uuid()) @db.Uuid
  canonicalName      String   @map("canonical_name")
  component          String? // service / component (e.g. 'AF', 'NAVY', 'ARMY', 'OSD')
  capabilityArea     String?  @map("capability_area")
  acquisitionPathway String?  @map("acquisition_pathway")
  /// MDAP code from the program_element_acquisition_program seed (e.g. '198'); null
  /// for programs introduced outside the curated MDAP map.
  mdapCode           String?  @map("mdap_code")
  description        String?  @db.Text
  status             String   @default("active") @db.VarChar(20)
  metadata           Json     @default("{}") @map("metadata_jsonb")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  aliases        ProgramAlias[]
  matches        PeProgramMatch[]
  samMatches     SamOpportunityMatch[]
  personRoles    PersonRole[]
  officeLinks    ProgramOfficeProgramLink[]
  provisionLinks ProvisionPeLink[]

  @@index([mdapCode], map: "program_mdap_code_idx")
  @@index([component], map: "program_component_idx")
  @@index([status], map: "program_status_idx")
  @@map("program")
}

/// Alias / known name for a Program — drives fuzzy PE/project -> program matching.
/// aliasNormalized is the upper-cased, punctuation-stripped form used for the
/// pg_trgm trigram index. aliasType records WHERE the alias came from so the
/// matcher can weight official names over usage strings.
model ProgramAlias {
  id              String   @id @default(uuid()) @db.Uuid
  programId       String   @map("program_id") @db.Uuid
  alias           String
  /// Upper-cased, punctuation-stripped form (see normalizeAlias in pe-program-matcher).
  aliasNormalized String   @map("alias_normalized")
  /// 'canonical' | 'acronym' | 'pe_title' | 'project_title' | 'p1_line_name' |
  /// 'mdap_name' | 'office_usage' | 'congressional' | 'sam_usage' | 'award_usage'.
  aliasType       String   @map("alias_type")
  source          String
  sourceUrl       String?  @map("source_url")
  confidence      Float    @default(0.9)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, aliasNormalized, aliasType], map: "program_alias_program_norm_type_key")
  @@index([programId], map: "program_alias_program_id_idx")
  @@index([aliasNormalized], map: "program_alias_normalized_idx")
  // NOTE: the pg_trgm GIN index on alias_normalized is created in raw SQL in the
  // migration (Prisma cannot express `USING gin (... gin_trgm_ops)`).
  @@map("program_alias")
}

/// PE (and optionally a project within it) -> Program link, with evidence and a
/// confidence tier. The graph's source of truth. Machine matches land here as
/// 'candidate'/'quarantined' for HUMAN review; 'accepted' is reserved for curated
/// seed rows and reviewer confirmations (and the documented official+exact
/// auto-accept rule). NEVER auto-accepted from a fuzzy path.
model PeProgramMatch {
  id               String    @id @default(uuid()) @db.Uuid
  peCode           String    @map("pe_code") @db.VarChar(16)
  /// Project (R-2A) code within the PE when the match is project-level, else null.
  projectCode      String?   @map("project_code") @db.VarChar(8)
  programId        String    @map("program_id") @db.Uuid
  score            Float
  /// 'exact_pe_number' | 'exact_project_title' | 'r2a_office_named' |
  /// 'other_funding_link' | 'official_office_page' | 'sar_msar' | 'sam_match' |
  /// 'award_match' | 'press_release' | 'news_only' | 'mdap_curated' (seed).
  evidenceTier     String    @map("evidence_tier")
  /// Array of evidence items: { kind, sourceUrl, pageNumber?, quote? }.
  evidence         Json      @default("[]") @map("evidence_jsonb")
  /// 'accepted' | 'candidate' | 'quarantined' | 'rejected'. Default derived from
  /// score+tier per the plan thresholds (see deriveMatchStatus).
  status           String    @default("candidate") @db.VarChar(20)
  /// True when score < 0.50 — stored as a weak signal, NEVER surfaced.
  weakSignal       Boolean   @default(false) @map("weak_signal")
  matchBasis       String?   @map("match_basis") @db.Text
  resolvedByUserId String?   @map("resolved_by_user_id") @db.Uuid
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz(6)
  decisionNotes    String?   @map("decision_notes") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  // Unique on (peCode, coalesce(projectCode,''), programId): a project-null and a
  // project-scoped match to the same program coexist; two matches with the same
  // (pe, project, program) do not. Postgres treats NULLs as distinct, so the
  // coalesce()-based uniqueness is enforced via a raw expression index in the
  // migration (Prisma cannot express a functional unique index).
  @@index([programId], map: "pe_program_match_program_id_idx")
  @@index([peCode], map: "pe_program_match_pe_code_idx")
  @@index([status], map: "pe_program_match_status_idx")
  @@map("pe_program_match")
}

// ─────────────────────────────────────────────────────────────────────────
// SAM.gov OPPORTUNITIES (Step 3.1) — DoD contract opportunities + review-gated
// opportunity -> program / PE matching. GLOBAL tables (no tenant_id / RLS): these
// describe public-domain federal solicitations, same as federal_award / program.
// SamOpportunityMatch mirrors PeProgramMatch / ProvisionPeLink review gating: a
// machine match lands as 'candidate' or 'quarantined'; only a verbatim PE-code hit
// in the description is 'accepted'. PSC/NAICS-only matches are NEVER auto-accepted.
// ─────────────────────────────────────────────────────────────────────────

/// A SAM.gov contract opportunity (solicitation / notice). One row per notice_id.
/// Loaded by sync-sam-opportunities (DoD-filtered, incremental). Global table —
/// no tenant_id, no RLS (federal reference data, same as federal_award).
model SamOpportunity {
  id                  String    @id @default(uuid()) @db.Uuid
  /// SAM.gov noticeId — stable idempotency key.
  noticeId            String    @unique @map("notice_id")
  solicitationNumber  String?   @map("solicitation_number")
  title               String
  /// SAM.gov notice type (e.g. 'Solicitation', 'Combined Synopsis/Solicitation',
  /// 'Presolicitation', 'Sources Sought', 'Award Notice').
  noticeType          String    @map("notice_type") @db.VarChar(32)
  agency              String?
  office              String?
  /// Product/Service Code.
  pscCode             String?   @map("psc_code") @db.VarChar(8)
  naicsCode           String?   @map("naics_code") @db.VarChar(8)
  postedDate          DateTime? @map("posted_date") @db.Timestamptz(6)
  responseDeadline    DateTime? @map("response_deadline") @db.Timestamptz(6)
  archiveDate         DateTime? @map("archive_date") @db.Timestamptz(6)
  description         String?   @db.Text
  /// Primary point-of-contact name (public header field).
  pocName             String?   @map("poc_name")
  pocEmail            String?   @map("poc_email")
  placeOfPerformance  Json      @default("{}") @map("place_of_performance_jsonb")
  sourceUrl           String?   @map("source_url")
  /// Derived from archiveDate: false once the notice's archive date has passed.
  active              Boolean   @default(true)
  raw                 Json      @default("{}") @map("raw_jsonb")
  lastSyncedAt        DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  matches SamOpportunityMatch[]

  @@index([active, responseDeadline], map: "sam_opportunity_active_response_deadline_idx")
  @@index([naicsCode], map: "sam_opportunity_naics_code_idx")
  @@index([pscCode], map: "sam_opportunity_psc_code_idx")
  @@index([office], map: "sam_opportunity_office_idx")
  @@map("sam_opportunity")
}

/// Review-gated SAM.gov opportunity -> Program (and/or PE) link, with a confidence
/// and a match basis. The graph's source of truth for "which opportunity belongs to
/// which program". Mirrors PeProgramMatch gating: machine matches land as
/// 'candidate'/'quarantined' for HUMAN review. A verbatim PE-code hit in the
/// description is the ONLY auto-'accepted' basis; PSC/NAICS-only matches are
/// 'quarantined' and NEVER auto-accepted.
model SamOpportunityMatch {
  id            String   @id @default(uuid()) @db.Uuid
  opportunityId String   @map("opportunity_id") @db.Uuid
  programId     String?  @map("program_id") @db.Uuid
  peCode        String?  @map("pe_code") @db.VarChar(16)
  /// 'program_alias' | 'office' | 'psc_naics_component' | 'description_pe_code'.
  matchBasis    String   @map("match_basis") @db.VarChar(24)
  confidence    Float    @default(0.5)
  /// 'candidate' | 'accepted' | 'quarantined' | 'rejected'. Default 'candidate';
  /// only 'description_pe_code' may be 'accepted'.
  reviewStatus  String   @default("candidate") @map("review_status") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  opportunity SamOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  program     Program?       @relation(fields: [programId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Unique on (opportunity_id, coalesce(program_id::text,''), coalesce(pe_code,'')) —
  // Postgres treats NULLs as distinct, so the coalesce()-based uniqueness is enforced
  // via a raw expression index in the migration (Prisma cannot express it).
  @@index([programId], map: "sam_opportunity_match_program_id_idx")
  @@index([peCode], map: "sam_opportunity_match_pe_code_idx")
  @@index([reviewStatus], map: "sam_opportunity_match_review_status_idx")
  @@map("sam_opportunity_match")
}

/// A captured narrative PROVISION from a congressional committee report (HASC/SASC
/// markup, HAC-D/SAC-D report, conference report) — the LANGUAGE that directs/adds/
/// cuts/restricts, not just the dollar tables (Step 2.4, plan §4.1 / §6 / §10). GLOBAL
/// public-domain congressional data (no tenant_id / RLS), like program /
/// source_document. Populated by the (follow-on) language-extraction loader.
model CommitteeReportProvision {
  id               String   @id @default(uuid()) @db.Uuid
  sourceDocumentId String?  @map("source_document_id") @db.Uuid
  /// Issuing committee short code: 'HASC' | 'SASC' | 'HAC-D' | 'SAC-D' | 'CONF'.
  committee        String   @db.VarChar(16)
  fy               Int
  /// The provision's heading / item title as it appears in the report.
  heading          String   @db.Text
  /// The full provision language (verbatim).
  text             String   @db.Text
  pageStart        Int?     @map("page_start")
  pageEnd          Int?     @map("page_end")
  /// Deterministic classifier output (see provision-action-classifier): 'directs_briefing'
  /// | 'directs_report' | 'adds' | 'cuts' | 'transfers' | 'restricts' | 'encourages' |
  /// 'expresses_concern'. Null when the language is ambiguous / unclassified.
  actionType       String?  @map("action_type") @db.VarChar(24)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  sourceDocument SourceDocument?   @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  links          ProvisionPeLink[]

  @@index([committee, fy], map: "committee_report_provision_committee_fy_idx")
  @@index([actionType], map: "committee_report_provision_action_type_idx")
  @@index([sourceDocumentId], map: "committee_report_provision_source_document_idx")
  @@map("committee_report_provision")
}

/// Review-gated link from a captured committee-report provision to a PE / project /
/// program. matchBasis records HOW the link was found ('pe_code' from a verbatim PE
/// number is accepted; fuzzy 'project_title' / 'program_alias' land as 'candidate').
/// GLOBAL congressional data (no tenant_id / RLS).
model ProvisionPeLink {
  id           String   @id @default(uuid()) @db.Uuid
  provisionId  String   @map("provision_id") @db.Uuid
  peCode       String?  @map("pe_code") @db.VarChar(16)
  projectCode  String?  @map("project_code") @db.VarChar(8)
  programId    String?  @map("program_id") @db.Uuid
  /// 'pe_code' | 'project_title' | 'program_alias' | 'manual' — how the link was found.
  matchBasis   String   @map("match_basis") @db.VarChar(24)
  confidence   Float    @default(0.5)
  /// 'accepted' | 'candidate' | 'rejected'. Verbatim PE-code links are 'accepted';
  /// fuzzy title/alias links land as 'candidate' for human review.
  reviewStatus String   @default("candidate") @map("review_status") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  provision CommitteeReportProvision @relation(fields: [provisionId], references: [id], onDelete: Cascade)
  program   Program?                 @relation(fields: [programId], references: [id], onDelete: SetNull)

  // Unique on (provisionId, coalesce(peCode,''), coalesce(programId::text,'')): Postgres
  // treats NULLs as distinct, so the coalesce()-based uniqueness is enforced via a raw
  // expression index in the migration (Prisma cannot express a functional unique index).
  @@index([peCode], map: "provision_pe_link_pe_code_idx")
  @@index([programId], map: "provision_pe_link_program_id_idx")
  @@index([reviewStatus], map: "provision_pe_link_review_status_idx")
  @@map("provision_pe_link")
}

/// A program/acquisition office (PEO, PM shop, CPE, contracting office, etc.).
/// People hang off OFFICES and ROLES, never directly off PEs (plan §8/§14). Global
/// reference data: no tenant_id / RLS, like program / acquisition_personnel.
/// Time-versioned for reorgs via validFrom/validTo.
model ProgramOffice {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  /// 'peo' | 'pm' | 'cpe' | 'pae' | 'directorate' | 'command' | 'contracting_office' | 'other'
  officeType     String    @map("office_type") @db.VarChar(24)
  service        String?   @db.VarChar(8)
  parentOfficeId String?   @map("parent_office_id") @db.Uuid
  sourceUrl      String?   @map("source_url")
  status         String    @default("active") @db.VarChar(16)
  validFrom      DateTime? @map("valid_from") @db.Timestamptz(6)
  validTo        DateTime? @map("valid_to") @db.Timestamptz(6)
  metadata       Json      @default("{}") @map("metadata_jsonb")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  parentOffice ProgramOffice?             @relation("ProgramOfficeParent", fields: [parentOfficeId], references: [id], onDelete: SetNull)
  childOffices ProgramOffice[]            @relation("ProgramOfficeParent")
  roles        PersonRole[]
  programLinks ProgramOfficeProgramLink[]

  @@index([service], map: "program_office_service_idx")
  @@index([officeType], map: "program_office_office_type_idx")
  @@index([parentOfficeId], map: "program_office_parent_idx")
  @@map("program_office")
}

/// A person's role at an office and/or on a program, with a compliance classification
/// (contactUse) and review gate. Replaces the free-text person->PE shortcut (plan §8).
/// Global reference data. staleAt set by the staleness job when observedAt > 180d
/// without re-assertion (stale roles are excluded from recommendation surfaces).
model PersonRole {
  id             String    @id @default(uuid()) @db.Uuid
  personId       String    @map("person_id") @db.Uuid
  officeId       String?   @map("office_id") @db.Uuid
  programId      String?   @map("program_id") @db.Uuid
  roleTitle      String    @map("role_title")
  /// 'peo' | 'pm' | 'deputy' | 'chief_engineer' | 'contracting_officer' | 'staff' | 'other'
  roleType       String    @map("role_type") @db.VarChar(24)
  source         String    @db.VarChar(64)
  sourceUrl      String?   @map("source_url")
  sourceQuote    String?   @map("source_quote") @db.Text
  observedAt     DateTime  @map("observed_at") @db.Timestamptz(6)
  effectiveStart DateTime? @map("effective_start") @db.Timestamptz(6)
  effectiveEnd   DateTime? @map("effective_end") @db.Timestamptz(6)
  confidence     Float     @default(0.5)
  /// 'accepted' | 'candidate' | 'quarantined'
  reviewStatus   String    @default("candidate") @map("review_status") @db.VarChar(20)
  /// 'lobbying_contact' | 'program_ownership_context' | 'official_procurement_poc' |
  /// 'internal_owner' | 'relationship_owner' | 'do_not_contact_procurement_sensitive' |
  /// 'candidate' | 'quarantined'. Set by the contact-use policy module.
  contactUse     String    @map("contact_use") @db.VarChar(40)
  staleAt        DateTime? @map("stale_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  person  AcquisitionPersonnel @relation(fields: [personId], references: [id], onDelete: Cascade)
  office  ProgramOffice?       @relation(fields: [officeId], references: [id], onDelete: SetNull)
  program Program?             @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@index([personId], map: "person_role_person_id_idx")
  @@index([officeId], map: "person_role_office_id_idx")
  @@index([programId], map: "person_role_program_id_idx")
  @@index([reviewStatus], map: "person_role_review_status_idx")
  @@index([contactUse], map: "person_role_contact_use_idx")
  @@map("person_role")
}

/// Office -> Program link (which office manages/executes/supports a program). Review-gated;
/// alias-derived links are 'candidate' only. Global reference data.
model ProgramOfficeProgramLink {
  id           String   @id @default(uuid()) @db.Uuid
  officeId     String   @map("office_id") @db.Uuid
  programId    String   @map("program_id") @db.Uuid
  /// 'manages' | 'executes' | 'supports'
  relation     String   @db.VarChar(16)
  sourceUrl    String?  @map("source_url")
  confidence   Float    @default(0.5)
  reviewStatus String   @default("candidate") @map("review_status") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  office  ProgramOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
  program Program       @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([officeId, programId], map: "program_office_program_link_office_program_key")
  @@index([programId], map: "program_office_program_link_program_id_idx")
  @@map("program_office_program_link")
}
