  title         String    @db.Text
  url           String?
  publishDate   DateTime? @map("publish_date") @db.Date
  reportType    String?   @map("report_type") // Report, Testimony, Correspondence
  topics        String[]  @default([])
  agencies      String[]  @default([]) // agencies covered
  summary       String?   @db.Text
  recommendations Int?    // number of recommendations
  syncedAt      DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([publishDate])
  @@index([reportType])
  @@map("gao_report")
}

// ─────────────────────────────────────────────────────────────────────────
// Open States — state legislature bills and legislators
// GLOBAL table — no tenant_id, no RLS.
// Source: v3.openstates.org/
// ─────────────────────────────────────────────────────────────────────────

model StateBill {
  id              String    @id // openstates bill ID
  state           String    // 2-letter state code
  session         String    // legislative session
  identifier      String    // e.g. "HB 1234"
  title           String    @db.Text
  chamber         String?   // upper, lower
  classification  String[]  @default([]) // bill, resolution, etc.
  subjects        String[]  @default([])
  sponsorName     String?   @map("sponsor_name")
  sponsorParty    String?   @map("sponsor_party")
  latestActionDate DateTime? @map("latest_action_date") @db.Date
  latestActionText String?  @map("latest_action_text")
  url             String?
  syncedAt        DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([state, session])
  @@index([state, latestActionDate])
  @@map("state_bill")
}

model StateLegislator {
  id          String   @id // openstates person ID
  name        String
  state       String
  chamber     String?  // upper, lower
  district    String?
  party       String?
  email       String?
  image       String?
  url         String?
  committees  Json     @default("[]") // [{name, role}]
  active      Boolean  @default(true)
  syncedAt    DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([state, chamber])
  @@index([party, state])
  @@map("state_legislator")
}

// ─────────────────────────────────────────────────────────────────────────
// CRS Reports — Congressional Research Service
// GLOBAL table — no tenant_id, no RLS.
// Source: crsreports.congress.gov (scrape index)
// ─────────────────────────────────────────────────────────────────────────

model CrsReport {
