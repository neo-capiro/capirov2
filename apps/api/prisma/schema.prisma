/// Step 3.2 — materiality-gated, client-specific action card (plan §10 card spec,
/// §19 workflow states). Tenant-scoped with RLS (mirrors ClientFacility). deltaId /
/// programId / peCode / ownerUserId are plain ids (no FK), matching repo convention.
model ActionRecommendation {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  clientId              String    @map("client_id") @db.Uuid
  peCode                String?   @map("pe_code") @db.VarChar(16)
  programId             String?   @map("program_id") @db.Uuid
  deltaId               String?   @map("delta_id") @db.Uuid
  actionType            String    @map("action_type") @db.VarChar(40)
  issueTitle            String    @map("issue_title") @db.Text
  whatChanged           String    @map("what_changed") @db.Text
  whyItMatters          String    @map("why_it_matters") @db.Text
  recommendedAction     String    @map("recommended_action") @db.Text
  targetAudience        Json      @default("[]") @map("target_audience_jsonb")
  suggestedArtifactType String?   @map("suggested_artifact_type") @db.VarChar(40)
  deadline              DateTime? @db.Date
  deadlineSource        String?   @map("deadline_source") @db.VarChar(24)
  ownerUserId           String?   @map("owner_user_id") @db.Uuid
  priority              Int       @default(0)
  confidence            Json      @default("{}") @map("confidence_jsonb")
  uncertainty           String?   @db.Text
  evidence              Json      @default("[]") @map("evidence_jsonb")
  status                String    @default("new") @db.VarChar(24)
  dismissalReason       String?   @map("dismissal_reason") @db.Text
  outcome               String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, deadline], map: "action_recommendation_tenant_status_deadline_idx")
  @@index([tenantId, clientId], map: "action_recommendation_tenant_client_idx")
  @@map("action_recommendation")
}

model Strategy {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  clientId        String   @map("client_id") @db.Uuid
  capabilityId    String?  @map("capability_id") @db.Uuid
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  name            String
  fiscalYear      String?  @map("fiscal_year")
  status          String   @default("active")
  description     String?  @db.Text
  submissionTypes Json     @default("[]") @map("submission_types_jsonb")
  settings        Json     @default("{}") @map("settings_jsonb")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Optional in Prisma even though the DB column is NOT NULL. The DB FK +
  // ON DELETE CASCADE prevent true orphans, but RLS / archived-status
  // filters in tenant-scoped queries can hide the client row from the
  // join while still returning the strategy row. Marking the Prisma
  // relation optional lets `include: { client: ... }` resolve to null
  // instead of throwing
  //   "Field client is required to return data, got null instead"
  // every time someone lists strategies for an archived client.
  client     Client?            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  capability ClientCapability?  @relation(fields: [capabilityId], references: [id], onDelete: SetNull)
  createdBy  User?              @relation("StrategyCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  targets    StrategyTarget[]
  instances  WorkflowInstance[]

  @@index([tenantId, clientId, status], map: "strategies_tenant_client_status_idx")
  @@map("strategies")
}

model StrategyTarget {
  id                     String    @id @default(uuid()) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  strategyId             String    @map("strategy_id") @db.Uuid
  acquisitionPersonnelId String?   @map("acquisition_personnel_id") @db.Uuid
  memberName             String    @map("member_name")
  memberTitle            String?   @map("member_title")
  memberParty            String?   @map("member_party")
  memberState            String?   @map("member_state")
  committee              String?
  subcommittee           String?
  stafferName            String?   @map("staffer_name")
  stafferEmail           String?   @map("staffer_email")
  directoryContactId     String?   @map("directory_contact_id")
  outreachStatus         String    @default("not_started") @map("outreach_status")
  meetingDate            DateTime? @map("meeting_date") @db.Timestamptz(6)
  notes                  String?   @db.Text
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([tenantId, strategyId], map: "strategy_targets_tenant_strategy_idx")
  @@index([acquisitionPersonnelId], map: "strategy_targets_acquisition_personnel_id_idx")
  @@map("strategy_targets")
}

model EngagementCampaign {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  clientId        String?   @map("client_id") @db.Uuid
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  name            String
  type            String    @default("custom")
  status          String    @default("draft")
  subject         String?
  body            String?   @db.Text
  sourceContext   Json      @default("{}") @map("source_context_jsonb")
  metadata        Json      @default("{}") @map("metadata_jsonb")
  sentAt          DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client     Client?                       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy  User                          @relation("CampaignCreator", fields: [createdByUserId], references: [id])
  recipients EngagementCampaignRecipient[]

  @@index([tenantId, clientId, status], map: "engagement_campaigns_tenant_client_status_idx")
  @@map("engagement_campaigns")
}

model EngagementCampaignRecipient {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  campaignId String    @map("campaign_id") @db.Uuid
  name       String?
  email      String
  title      String?
  office     String?
  status     String    @default("pending")
  sentAt     DateTime? @map("sent_at") @db.Timestamptz(6)
  metadata   Json      @default("{}") @map("metadata_jsonb")
