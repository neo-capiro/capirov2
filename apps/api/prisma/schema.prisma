// Budget-cycle (PB position) dimension + FYDP outyears (Step 1.3, plan §5/§6).
// ONE row per (PE, budget cycle, asserted FY, value kind): every fiscal year a
// budget book *asserts* a value FOR, tagged with the book/stage that asserts it.
// This single shape stores FY27 PB's FY27 request AND FY27 PB's FY28-31 outyears
// AND FY26 PB's FY27 projection — exactly what PB-vs-prior-PB and outyear-delta
// computation need. ADDITIVE: ProgramElementYear remains the "current consolidated
// stage ladder" the profile UI renders today; nothing here changes that consumer.
//
// Global table (no tenant_id / RLS): public-domain budget data, same as
// program_element / federal_award. Mirrors ProgramElementSource provenance
// conventions (sourceUrl + pageNumber deep link, nullable source_document_id FK).
//
// positionCycle = the book/stage asserting the values, e.g.
//   'pb_fy2026' | 'pb_fy2027' | 'hasc_fy2027' | 'enacted_fy2026' | ...
// assertedFy    = the fiscal year the dollars/quantity are FOR (the FYDP column).
// valueKind     = 'total' (dollars $M) | 'quantity' (units) | 'unit_cost' ($M/unit).
// amount is in $ MILLIONS for 'total'/'unit_cost' (project money convention); for
// 'quantity' rows amount carries the unit count and `quantity` may duplicate it.
model ProgramElementBudgetPosition {
  id               String   @id @default(uuid()) @db.Uuid
  peCode           String   @map("pe_code") @db.VarChar(16)
  positionCycle    String   @map("position_cycle")
  assertedFy       Int      @map("asserted_fy")
  amount           Decimal  @db.Decimal(14, 2)
  quantity         Decimal? @db.Decimal(14, 2)
  valueKind        String   @map("value_kind") // total | quantity | unit_cost
  sourceUrl        String?  @map("source_url")
  pageNumber       Int?     @map("page_number")
  metadata         Json     @default("{}") @map("metadata_jsonb")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  // Registry link (Step 0.1): the fingerprinted source file this position came from.
  sourceDocumentId String?  @map("source_document_id") @db.Uuid

  programElement ProgramElement  @relation(fields: [peCode], references: [peCode], onDelete: Cascade)
  sourceDocument SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([peCode, positionCycle, assertedFy, valueKind], map: "program_element_budget_position_natural_key")
  @@index([peCode, assertedFy], map: "program_element_budget_position_pe_fy_idx")
  @@index([positionCycle], map: "program_element_budget_position_cycle_idx")
  @@index([sourceDocumentId], map: "program_element_budget_position_source_document_idx")
  @@map("program_element_budget_position")
}

// Typed, materiality-scored budget delta (Step 1.4, plan §6). ONE row per
// (PE, asserted FY, delta type, fromRef, toRef) — the engine recomputes it
// idempotently from ProgramElementYear / ProgramElementBudgetPosition /
// ProgramElementProcurementLine. Latest-wins: a recompute that finds a changed
// magnitude stamps `supersededAt` on the prior live row (supersededAt IS NULL)
// and inserts a fresh one, so history is preserved without breaking the natural
// key. Global table (no tenant_id / RLS): the delta itself is public-domain budget
// math; clientRelevance is computed PER-TENANT at read time and is NEVER stored.
//
// deltaType (text, enum-as-text — keep parsers tolerant of new types):
//   pb_vs_prior_pb | mark_vs_request | mark_vs_mark | conference_vs_marks |
//   enacted_vs_request | new_start | termination | zeroed | transfer_candidate |
//   quantity_change | unit_cost_change | outyear_shift | project_level_change
// fromRef / toRef = the positionCycle or field name each side reads (e.g.
//   'request'→'hascMark', or 'pb_fy2026'→'pb_fy2027').
// materialityScore (0..1) + materialityFactors (per-factor contributions) come
// from the PURE scorer (deltas/materiality-scorer.ts); clientRelevance is layered
// in at read time, never persisted.
model ProgramElementDelta {
  id                 String    @id @default(uuid()) @db.Uuid
  peCode             String    @map("pe_code") @db.VarChar(16)
  assertedFy         Int       @map("asserted_fy")
  deltaType          String    @map("delta_type")
  fromRef            String?   @map("from_ref")
  toRef              String?   @map("to_ref")
  amountFrom         Decimal?  @map("amount_from") @db.Decimal(14, 2)
  amountTo           Decimal?  @map("amount_to") @db.Decimal(14, 2)
  deltaAbs           Decimal?  @map("delta_abs") @db.Decimal(14, 2)
  deltaPct           Float?    @map("delta_pct")
  // Exact-copy change-summary narrative (Step 1.5 attaches it; never generated).
  explanation        String?   @db.Text
  // Source rows/pages used to compute this delta (provenance for the "evidence chip").
  evidence           Json      @default("{}") @map("evidence_jsonb")
  materialityScore   Float     @map("materiality_score")
  materialityFactors Json      @default("{}") @map("materiality_factors_jsonb")
  computedAt         DateTime  @default(now()) @map("computed_at") @db.Timestamptz(6)
  // Set on the OLD row when a recompute supersedes it; NULL = current live delta.
  supersededAt       DateTime? @map("superseded_at") @db.Timestamptz(6)

  programElement ProgramElement @relation(fields: [peCode], references: [peCode], onDelete: Cascade)

  // NOTE: the natural-key uniqueness is enforced by a PARTIAL functional unique index
  // (WHERE superseded_at IS NULL, COALESCE-ing the nullable from/to refs) created in
  // the migration raw SQL — Prisma 5 cannot express partial/functional unique indexes,
  // so this is a plain compound index here (kept queryable) and the migration adds the
  // partial unique constraint. Latest-wins: superseded rows share the natural key.
  @@index([peCode, assertedFy, deltaType, fromRef, toRef], map: "program_element_delta_natural_key_idx")
  @@index([peCode, assertedFy], map: "program_element_delta_pe_fy_idx")
  @@index([deltaType], map: "program_element_delta_type_idx")
  @@index([materialityScore(sort: Desc)], map: "program_element_delta_score_idx")
  @@index([supersededAt], map: "program_element_delta_superseded_idx")
  @@map("program_element_delta")
}

model ProgramElementMilestone {
  id            String    @id @default(uuid()) @db.Uuid
  peCode        String    @map("pe_code") @db.VarChar(16)
  milestoneType String    @map("milestone_type")
  plannedDate   DateTime? @map("planned_date") @db.Date
  actualDate    DateTime? @map("actual_date") @db.Date
  status        String?
  source        String
  notes         String?   @db.Text
  lastSyncedAt  DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  programElement ProgramElement @relation(fields: [peCode], references: [peCode], onDelete: Cascade)

  @@unique([peCode, milestoneType], map: "program_element_milestone_pe_code_type_key")
  @@index([status], map: "program_element_milestone_status_idx")
  @@map("program_element_milestone")
}

model ProgramElementQuarantine {
  id            String   @id @default(uuid()) @db.Uuid
  rawRecord     Json     @map("raw_record")
  reason        String
  source        String
  quarantinedAt DateTime @default(now()) @map("quarantined_at") @db.Timestamptz(6)

  @@map("program_element_quarantine")
}

model ProgramElementYearSourceValue {
  id               String   @id @default(uuid()) @db.Uuid
  peCode           String   @map("pe_code") @db.VarChar(16)
  fy               Int
  fieldName        String   @map("field_name")
  source           String
  valueJsonb       Json     @default("null") @map("value_jsonb")
  // Per-field reconciliation values (Step 29 §4.1). value_decimal for numeric
  // marks/dollars, value_text for narrative fields. written_at mirrors recordedAt
  // for the reconciliation queue's naming.
  valueDecimal     Decimal? @map("value_decimal") @db.Decimal(18, 2)
  valueText        String?  @map("value_text") @db.Text
  writtenAt        DateTime @default(now()) @map("written_at") @db.Timestamptz(6)
  isWinner         Boolean  @default(false) @map("is_winner")
  recordedAt       DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)
  // Registry link (Step 0.1): the fingerprinted source file this per-field value came from.
  sourceDocumentId String?  @map("source_document_id") @db.Uuid

  programElement ProgramElement  @relation(fields: [peCode], references: [peCode], onDelete: Cascade)
  sourceDocument SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([peCode, fy, fieldName], map: "program_element_year_source_value_lookup_idx")
  @@index([peCode, fy, fieldName, isWinner], map: "program_element_year_source_value_winner_idx")
  @@index([sourceDocumentId], map: "program_element_year_source_value_source_document_idx")
  @@map("program_element_year_source_value")
}

// Registry of fingerprinted, versioned source files behind extracted defense-budget
// rows (Step 0.1, plan §4.2/§4.3). GLOBAL table (no tenant_id / RLS): public-domain
// reference data, same as program_element / federal_award.
//
// Versioning: exactly ONE *live* document per sourceKey (supersededByDocumentId IS NULL);
// re-ingesting identical content (same sourceKey + sha256) is a no-op, while a CHANGED
// sha256 for a sourceKey creates a new row and chains the prior live head via
// supersededByDocumentId. "One live per sourceKey" is enforced by upsertSourceDocument
// (source-document-registry.ts), not a DB partial index (Prisma 5 can't express one); the
// UNIQUE(source_key, sha256) below guarantees checksum de-duplication. Populated by the
// artifact-loading sync/parse scripts (which upsert their document first) and by
// backfill-source-documents.ts.
model SourceDocument {
  id                     String    @id @default(uuid()) @db.Uuid
  // Stable human key, derived from the committed artifact filename (e.g. 'jbook_r1_fy2027').
  sourceKey              String    @map("source_key")
  fiscalYear             Int?      @map("fiscal_year")
  // pb | hasc | sasc | hac_d | sac_d | conference | enacted | supplemental
  budgetCycle            String    @map("budget_cycle")
  // ARMY | NAVY | AF | SF | DW | ... (null for the all-component R-1 master list / committee docs)
  component              String?
  // r1 | r2 | r3 | p1 | p40 | committee_report | conference_report | public_law | other
  documentType           String    @map("document_type")
  title                  String
  // Source PDF URL (J-books); the artifact's source filename when no URL exists (committee docs).
  sourceUrl              String    @map("source_url")
  sha256                 String?   @db.Char(64)
  byteSize               Int?      @map("byte_size")
  pageCount              Int?      @map("page_count")
  downloadedAt           DateTime? @map("downloaded_at") @db.Timestamptz(6)
  // Path under apps/api/scripts/__data__/ for the committed extraction artifact.
  artifactPath           String?   @map("artifact_path")
  // structured_import | deterministic_pdf | manual
  extractionMethod       String    @map("extraction_method")
  extractionToolVersion  String?   @map("extraction_tool_version")
  ingestedAt             DateTime  @default(now()) @map("ingested_at") @db.Timestamptz(6)
  // Version chain: set on the OLD head when a newer version of the same sourceKey is ingested.
  supersededByDocumentId String?   @map("superseded_by_document_id") @db.Uuid
  metadata               Json      @default("{}") @map("metadata_jsonb")

  supersededBy SourceDocument?  @relation("SourceDocumentVersion", fields: [supersededByDocumentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  supersedes   SourceDocument[] @relation("SourceDocumentVersion")

  programElementSources    ProgramElementSource[]
  programElementProjects   ProgramElementProject[]
  programElementPerformers ProgramElementPerformer[]
  yearSourceValues         ProgramElementYearSourceValue[]
  budgetPositions          ProgramElementBudgetPosition[]
  provisions               CommitteeReportProvision[]

  @@unique([sourceKey, sha256], map: "source_document_source_key_sha256_key")
  @@index([documentType, fiscalYear, budgetCycle, component], map: "source_document_type_fy_cycle_component_idx")
  @@index([sourceKey], map: "source_document_source_key_idx")
  @@map("source_document")
}

/// Cross-source reconciliation review queue (Step 29 §4.1). An entry is queued when
/// a lower-priority source conflicts with the canonical value by > 10% (non-enacted
/// fields) or by ANY amount on the enacted field. capiro_admin resolves entries.
model ReconciliationReviewQueue {
  id                String    @id @default(uuid()) @db.Uuid
  peCode            String    @map("pe_code") @db.VarChar(16)
  fy                Int
  fieldName         String    @map("field_name")
  currentValue      String?   @map("current_value")
  conflictingSource String    @map("conflicting_source")
  conflictingValue  String?   @map("conflicting_value")
  deltaPct          Float?    @map("delta_pct")
  queuedAt          DateTime  @default(now()) @map("queued_at") @db.Timestamptz(6)
  status            String    @default("open") @db.VarChar(20)
  resolvedByUserId  String?   @map("resolved_by_user_id") @db.Uuid
  resolvedAt        DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolutionNotes   String?   @map("resolution_notes") @db.Text

  @@index([status, queuedAt(sort: Desc)], map: "reconciliation_review_queue_status_idx")
  @@index([peCode, fy], map: "reconciliation_review_queue_pe_fy_idx")
  @@map("reconciliation_review_queue")
}

model ProgramElementWatch {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  peCode    String   @map("pe_code") @db.VarChar(16)
