  sourceType    String?  @map("source_type") // 'comment_deadline' | 'change' | 'hearing' | 'manual' | ...
  title         String
  body          String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId])
  @@index([clientId])
  @@map("client_brief")
}

