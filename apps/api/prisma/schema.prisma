/// Chat attachment uploaded via POST /clio/attachments (F1). The stream
/// request references rows by id; documents store extracted text, images
/// store the raw bytes so vision blocks can be rebuilt on regenerate.
/// messageId is a plain column (no FK) so resend-mode message deletion never
/// trips a constraint; unconsumed rows (messageId null) older than 24h are
/// swept opportunistically on the next upload.
model ClioAttachment {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  messageId   String?  @map("message_id") @db.Uuid
  filename    String   @db.VarChar(300)
  /// pdf | docx | image | text
  kind        String   @db.VarChar(20)
  /// parsed | truncated | scanned | image_ready | unsupported
  status      String   @db.VarChar(20)
  mediaType   String?  @map("media_type") @db.VarChar(100)
  byteSize    Int      @map("byte_size")
  pages       Int?
  /// Extracted text for document kinds (clamped server-side).
  textContent String?  @map("text_content") @db.Text
  /// Human-readable reason when status is scanned/unsupported.
  reason      String?  @db.VarChar(300)
  /// Raw image bytes (image kind only) for vision-block assembly.
  data        Bytes?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation("ClioAttachmentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt(sort: Desc)], map: "clio_attachments_tenant_user_created_idx")
  @@index([messageId], map: "clio_attachments_message_idx")
  @@map("clio_attachments")
}

/// Deep Research sessions. A lobbyist starts a research session with a topic;
/// Clio proposes a plan + clarifying questions, the user answers, and Clio runs
/// a multi-round agentic investigation across all internal data tools + the web,
/// then synthesizes a long, cited report. The final report is persisted as a
/// ClioArtifact (kind = 'research_report'); this row tracks the lifecycle and
/// the inputs that produced it so a session can be resumed/audited.
model ClioResearchSession {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  clientId            String?  @map("client_id") @db.Uuid
  title               String
  topic               String   @db.Text
  /// plan | awaiting_clarification | researching | complete | failed
  status              String   @default("plan")
  /// AI-proposed clarifying questions (string[]) awaiting answers.
  clarifyingQuestions Json     @default("[]") @map("clarifying_questions_jsonb")
  /// User answers to the clarifying questions (keyed by question index).
  clarifyingAnswers   Json     @default("{}") @map("clarifying_answers_jsonb")
  /// AI-proposed research plan (list of sub-questions / angles).
  plan                Json     @default("[]")
  /// Source attributions gathered during the run.
  sources             Json     @default("[]")
  /// The final synthesized report artifact, once produced.
  reportArtifactId    String?  @map("report_artifact_id") @db.Uuid
  metadata            Json     @default("{}") @map("metadata_jsonb")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation("ClioResearchSessionUser", fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, updatedAt(sort: Desc)], map: "clio_research_sessions_tenant_user_updated_idx")
  @@index([tenantId, clientId, updatedAt(sort: Desc)], map: "clio_research_sessions_tenant_client_updated_idx")
  @@map("clio_research_sessions")
}

model ClioNote {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  clientId       String?  @map("client_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  meetingId      String?  @map("meeting_id") @db.Uuid
  title          String?
  body           String   @db.Text
  source         String   @default("clio")
  metadata       Json     @default("{}") @map("metadata_jsonb")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User              @relation("ClioNoteUser", fields: [userId], references: [id], onDelete: Cascade)
  client       Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  conversation ClioConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  meeting      Meeting?          @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, createdAt(sort: Desc)], map: "clio_notes_tenant_user_created_idx")
  @@index([tenantId, clientId, createdAt(sort: Desc)], map: "clio_notes_tenant_client_created_idx")
  @@index([conversationId, createdAt(sort: Desc)], map: "clio_notes_conversation_created_idx")
  @@map("clio_notes")
}

model ClioMemory {
  id          String                 @id @default(uuid()) @db.Uuid
  tenantId    String                 @map("tenant_id") @db.Uuid
  // Stored as TEXT in the DB with a CHECK constraint (scope IN ('firm','user_private'))
  // per the 20260525103000_clio_memory_scope_hardening migration. Modeled as String
  // (not a Prisma enum) so the generated client never casts to a "ClioMemoryScope"
  // Postgres type — that type was never created, and the enum decl caused
  // `type "public.ClioMemoryScope" does not exist` (42704) 500s on Clio memory reads.
  // App-level union typing lives in clio/clio-memory.helpers.ts (ClioMemoryScope = 'firm' | 'user_private').
  scope       String                 @default("firm")
  ownerUserId String?                @map("owner_user_id") @db.Uuid
  key         String                 @db.VarChar(200)
  value       String                 @db.Text
  source      String                 @default("conversation")
  embedding   Unsupported("vector")?
  metadata    Json                   @default("{}") @map("metadata_jsonb")
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, scope, ownerUserId, key], map: "clio_memory_tenant_scope_owner_key_uniq")
  @@index([tenantId, scope, ownerUserId, updatedAt(sort: Desc)], map: "clio_memory_scope_owner_updated_idx")
  @@index([tenantId, scope, updatedAt(sort: Desc)], map: "clio_memory_scope_updated_idx")
  @@map("clio_memory")
}

/// Clio self-scheduled recurring task (W3). A user asks Clio to run something on
/// a cadence (e.g. a weekly research brief). The runner (scripts/run-clio-scheduled-tasks.ts)
/// executes due rows through the Clio tool engine with the task's tool allow-list.
/// Scope mirrors ClioMemory ('firm' shared | 'user_private' owner-only). Tenant-cascade.
model ClioScheduledTask {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  ownerUserId   String   @map("owner_user_id") @db.Uuid
  // 'firm' | 'user_private' (TEXT + app-level union, same rationale as ClioMemory).
  scope         String   @default("user_private")
  name          String   @db.VarChar(200)
  // The instruction Clio runs each tick (a natural-language prompt).
  prompt        String   @db.Text
  // Cadence in minutes between runs (>=60 enforced at the tool layer).
  intervalMinutes Int    @map("interval_minutes")
  // JSON array of tool names this task is allowed to call. Defaults to read-only
  // research tools; side-effecting tools require explicit opt-in + confirm.
  toolAllowList Json     @default("[]") @map("tool_allow_list")
  enabled       Boolean  @default(true)
  lastRunAt     DateTime? @map("last_run_at") @db.Timestamptz(6)
  nextRunAt     DateTime @map("next_run_at") @db.Timestamptz(6)
  lastStatus    String?  @map("last_status") @db.VarChar(20)
  runCount      Int      @default(0) @map("run_count")
  createdBy     String   @default("clio") @map("created_by") @db.VarChar(40)
  metadata      Json     @default("{}") @map("metadata_jsonb")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, ownerUserId, createdAt(sort: Desc)], map: "clio_scheduled_task_tenant_owner_idx")
  @@index([enabled, nextRunAt], map: "clio_scheduled_task_due_idx")
  @@map("clio_scheduled_task")
}

/// Tenant-configured MCP server (F6a). Bearer tokens for streamable-HTTP
/// servers are AES-256-GCM encrypted at rest (same pattern as
/// IntegrationConnectionToken) and never stored or returned in plaintext.
/// Tools are bridged as mcp__<name>__<tool>; only allowlisted tools register,
/// and every bridged tool is treated as side-effecting unless listed in
/// readOnlyTools.
model ClioMcpServer {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  name                String    @db.VarChar(64)
  /// http (streamable HTTP) | stdio (ops-managed local child process)
  transport           String    @db.VarChar(10)
  endpoint            String?   @db.VarChar(500)
  command             String?   @db.VarChar(500)
  args                Json      @default("[]")
  envJson             Json      @default("{}") @map("env_jsonb")
  authTokenCiphertext String?   @map("auth_token_ciphertext")
  authTokenIv         String?   @map("auth_token_iv")
  authTokenAuthTag    String?   @map("auth_token_auth_tag")
  authKeyVersion      String?   @map("auth_key_version")
  toolAllowlist       Json      @default("[]") @map("tool_allowlist")
  readOnlyTools       Json      @default("[]") @map("read_only_tools")
  enabled             Boolean   @default(true)
  lastSyncAt          DateTime? @map("last_sync_at") @db.Timestamptz(6)
  lastError           String?   @map("last_error")
  createdByUserId     String?   @map("created_by_user_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name], map: "clio_mcp_servers_tenant_name_unique")
  @@index([tenantId, enabled], map: "clio_mcp_servers_tenant_enabled_idx")
  @@map("clio_mcp_servers")
}

/// Firm-authored Clio skill (F6b). skillJson holds the validated FirmSkill
/// shape (id, name, triggers, systemAddendum, requiredTools, template);
/// versions holds prior skillJson snapshots (newest first) for restore.
/// Built-in skills always win on trigger conflict via the registry safe-merge.
model ClioFirmSkill {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  skillId         String   @map("skill_id") @db.VarChar(48)
  name            String   @db.VarChar(80)
  skillJson       Json     @map("skill_jsonb")
  version         Int      @default(1)
  versions        Json     @default("[]") @map("versions_jsonb")
  enabled         Boolean  @default(true)
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, skillId], map: "clio_firm_skills_tenant_skill_unique")
  @@index([tenantId, enabled, updatedAt(sort: Desc)], map: "clio_firm_skills_tenant_enabled_idx")
  @@map("clio_firm_skills")
}

/// One row per AI generation: tenant, workflow, provider/model, token counts
/// and the ESTIMATED cost (computeAiCostUsd, hand-maintained pricing table).
/// usedTenantKey marks generations billed to the tenant's own provider key
/// rather than Capiro's shared key. Metering writes are best-effort — a
/// failed insert never fails the user's generation.
model AiUsageEvent {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  /// 'outreach_campaign' | 'meeting_prep' | 'meeting_debrief' | 'campaign_email' | 'talking_points' | ...
  workflow      String   @db.VarChar(48)
  /// 'openai' | 'anthropic'
  provider      String   @db.VarChar(16)
  model         String   @db.VarChar(80)
  inputTokens   Int      @map("input_tokens")
  outputTokens  Int      @map("output_tokens")
  costUsd       Decimal  @map("cost_usd") @db.Decimal(12, 6)
  usedTenantKey Boolean  @default(false) @map("used_tenant_key")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt], map: "ai_usage_events_tenant_created_idx")
  @@map("ai_usage_events")
}

model ClioProactiveAlert {
