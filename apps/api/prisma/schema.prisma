// Capiro identity / tenancy core schema.
// Scope: tenants, users, tenant_memberships, clerk_events, audit_logs.
// All tenant-scoped tables carry tenant_id NOT NULL and are protected by
// Postgres Row-Level Security policies created in the SQL migration.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // Bookworm slim runtime is OpenSSL 3.x on linux-arm64. `native` covers the
  // build host, the explicit target covers cross-arch builds (e.g. building
  // the ARM64 image from an x86 dev machine via buildx).
  binaryTargets   = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pg_trgm, citext, uuidOssp(map: "uuid-ossp")]
}

enum TenantRole {
  capiro_admin
  user_admin
  standard_user
  client_portal_user

  @@map("tenant_role")
}

enum TenantStatus {
  active
  suspended
  pending

  @@map("tenant_status")
}

enum MembershipStatus {
  invited
  active
  removed

  @@map("membership_status")
}

enum EngagementProvider {
  microsoft_365
  google_workspace
  imap_caldav
  manual

  @@map("engagement_provider")
}

enum EngagementConnectionStatus {
  needs_configuration
  connected
  error
  disabled

  @@map("engagement_connection_status")
}

enum EngagementSource {
  outlook
  google
  imap_caldav
  manual

  @@map("engagement_source")
}

enum AssociationEntityType {
  meeting
  mail_thread
  mail_message
  contact
  task

  @@map("association_entity_type")
}

enum MeetingPrepStatus {
  generated
  edited
  approved
  stale
  failed

  @@map("meeting_prep_status")
}

enum EngagementTaskStatus {
  todo
  in_progress
  done
  blocked
  canceled

  @@map("engagement_task_status")
}

enum WorkflowStatus {
  triage
  in_progress
  review
  submitted
  complete
  cancelled

  @@map("workflow_status")
}

model Tenant {
  id              String       @id @default(uuid()) @db.Uuid
  slug            String       @unique @db.Citext
  name            String
  status          TenantStatus @default(pending)
  plan            String?
  settings        Json         @default("{}") @map("settings_jsonb")
  kmsKeyArn       String?      @map("kms_key_arn")
  soc2AuditWindow Json?        @map("soc2_audit_window")
  // Clerk Organization id this tenant maps to. Populated by the
  // bootstrap-tenant script and used by the middleware to cross-check the
  // Clerk JWT's `org_id` claim against the tenant resolved via slug/UUID.
  clerkOrgId      String?      @unique @map("clerk_org_id")
  // Brand assets — logo lives in S3 under `tenants/{id}/branding/...`.
  // Upload is gated to user_admin (own tenant) and capiro_admin (any tenant).
  logoS3Key       String?      @map("logo_s3_key")
  logoContentType String?      @map("logo_content_type")
  logoUploadedAt  DateTime?    @map("logo_uploaded_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships                TenantMembership[]
  auditLogs                  AuditLog[]
  clients                    Client[]
  impersonationSessions      ImpersonationSession[]
  engagementConnections      IntegrationConnection[]
  engagementConnectionTokens IntegrationConnectionToken[]
  engagementContacts         EngagementContact[]
  meetings                   Meeting[]
  meetingAttendees           MeetingAttendee[]
  mailThreads                MailThread[]
  mailMessages               MailMessage[]
  engagementAttachments      EngagementAttachment[]
  meetingNotes               MeetingNote[]
  meetingPreps               MeetingPrep[]
  engagementTasks            EngagementTask[]
  associationOverrides       ClientAssociationOverride[]
  contextEmbeddings          ContextEmbedding[]
  directoryContactNotes      DirectoryContactNote[]
  engagementReportTargets    EngagementReportTargetOffice[]
  outreachRecords            OutreachRecord[]
  outreachTemplates          OutreachTemplate[]
  MeetingDebrief             MeetingDebrief[]
  clioConversations          ClioConversation[]
  clioMessages               ClioMessage[]
  clioArtifacts              ClioArtifact[]
  clioNotes                  ClioNote[]
  workflowInstances          WorkflowInstance[]
  clientCapabilities         ClientCapability[]
  clientSubmissionHistory    ClientSubmissionHistory[]
  clientPeople               ClientPerson[]
  strategies                 Strategy[]
  strategyTargets            StrategyTarget[]
  engagementCampaigns        EngagementCampaign[]
  engagementCampaignRecipients EngagementCampaignRecipient[]
  outreachAiTemplates        OutreachAiTemplate[]
  clioMemories               ClioMemory[]
  clioProactiveAlerts        ClioProactiveAlert[]

  @@map("tenants")
}

model User {
  id          String    @id @default(uuid()) @db.Uuid
  clerkUserId String    @unique @map("clerk_user_id")
  email       String    @unique @db.Citext
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  lastSeenAt  DateTime? @map("last_seen_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships             TenantMembership[]
  auditLogs               AuditLog[]                     @relation("AuditActor")
  impersonationSessions   ImpersonationSession[]         @relation("ImpersonationActor")
  directoryContactNotes   DirectoryContactNote[]         @relation("DirectoryContactNoteAuthor")
  meetingNotes            MeetingNote[]                  @relation("MeetingNoteAuthor")
  meetingDebriefs         MeetingDebrief[]               @relation("MeetingDebriefAuthor")
  engagementReportTargets EngagementReportTargetOffice[] @relation("EngagementReportTargetOfficeAuthor")
  outreachRecords         OutreachRecord[]               @relation("OutreachRecordAuthor")
  outreachTemplates       OutreachTemplate[]             @relation("OutreachTemplateAuthor")
  outreachAiTemplates     OutreachAiTemplate[]           @relation("OutreachAiTemplateAuthor")
  clioConversations       ClioConversation[]             @relation("ClioConversationUser")
  clioMessages            ClioMessage[]                  @relation("ClioMessageUser")
  clioArtifacts           ClioArtifact[]                 @relation("ClioArtifactUser")
  clioNotes               ClioNote[]                     @relation("ClioNoteUser")
  workflowInstances       WorkflowInstance[]             @relation("WorkflowInstanceCreator")
  strategies              Strategy[]                     @relation("StrategyCreator")
  createdCampaigns        EngagementCampaign[]           @relation("CampaignCreator")

  @@map("users")
}

model TenantMembership {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  role      TenantRole
  status    MembershipStatus @default(invited)
  invitedBy String?          @map("invited_by") @db.Uuid
  joinedAt  DateTime?        @map("joined_at") @db.Timestamptz(6)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId], map: "tenant_memberships_tenant_user_unique")
  @@index([tenantId, role], map: "tenant_memberships_tenant_role_idx")
  @@index([userId], map: "tenant_memberships_user_idx")
  @@map("tenant_memberships")
}

model ClerkEvent {
  id          String    @id @default(uuid()) @db.Uuid
  eventId     String    @unique @map("event_id")
  eventType   String    @map("event_type")
  payload     Json      @map("payload_jsonb")
  receivedAt  DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  error       String?

  @@index([eventType], map: "clerk_events_event_type_idx")
  @@map("clerk_events")
}

model Client {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  name                String
  website             String?
  description         String?
  productDescription  String?   @map("product_description")
  primaryContactName  String?   @map("primary_contact_name")
  primaryContactEmail String?   @map("primary_contact_email") @db.Citext
  primaryContactPhone String?   @map("primary_contact_phone")
  logoS3Key           String?   @map("logo_s3_key")
  logoContentType     String?   @map("logo_content_type")
  logoUploadedAt      DateTime? @map("logo_uploaded_at") @db.Timestamptz(6)
  intakeData          Json      @default("{}") @map("intake_data_jsonb")
  status              String    @default("active")
  createdByUserId     String?   @map("created_by_user_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                  Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  engagementContacts      EngagementContact[]
  meetings                Meeting[]
  mailThreads             MailThread[]
  engagementAttachments   EngagementAttachment[]
  meetingNotes            MeetingNote[]
  meetingDebriefs         MeetingDebrief[]
  meetingPreps            MeetingPrep[]
  engagementTasks         EngagementTask[]
  associationOverrides    ClientAssociationOverride[]
  engagementReportTargets EngagementReportTargetOffice[]
  outreachRecords         OutreachRecord[]
  clioConversations       ClioConversation[]
  clioMessages            ClioMessage[]
  clioArtifacts           ClioArtifact[]
  clioNotes               ClioNote[]
  workflowInstances       WorkflowInstance[]
  capabilities            ClientCapability[]
  submissionHistory       ClientSubmissionHistory[]
  people                  ClientPerson[]
  strategies              Strategy[]
  engagementCampaigns     EngagementCampaign[]
  clioProactiveAlerts     ClioProactiveAlert[]

  @@index([tenantId], map: "clients_tenant_idx")
  @@index([tenantId, name], map: "clients_tenant_name_idx")
  @@map("clients")
}

model DirectoryContactNote {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  directoryContactId   String   @map("directory_contact_id")
  directoryContactName String?  @map("directory_contact_name")
  body                 String   @db.Text
  createdByUserId      String?  @map("created_by_user_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("DirectoryContactNoteAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, directoryContactId, createdAt], map: "directory_contact_notes_tenant_contact_created_idx")
  @@index([createdByUserId], map: "directory_contact_notes_created_by_idx")
  @@map("directory_contact_notes")
}

model IntegrationConnection {
  id              String                     @id @default(uuid()) @db.Uuid
  tenantId        String                     @map("tenant_id") @db.Uuid
  provider        EngagementProvider
  accountEmail    String?                    @map("account_email") @db.Citext
  displayName     String?                    @map("display_name")
  status          EngagementConnectionStatus @default(needs_configuration)
  scopes          String[]                   @default([])
  syncState       Json                       @default("{}") @map("sync_state_jsonb")
  lastSyncAt      DateTime?                  @map("last_sync_at") @db.Timestamptz(6)
  nextSyncAt      DateTime?                  @map("next_sync_at") @db.Timestamptz(6)
  lastError       String?                    @map("last_error")
  createdByUserId String?                    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  token        IntegrationConnectionToken?
  meetings     Meeting[]
  mailThreads  MailThread[]
  mailMessages MailMessage[]

  @@unique([tenantId, provider, accountEmail], map: "engagement_connections_tenant_provider_account_key")
  @@index([tenantId, status], map: "engagement_connections_tenant_status_idx")
  @@map("engagement_connections")
}

model IntegrationConnectionToken {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @map("tenant_id") @db.Uuid
  connectionId           String   @unique @map("connection_id") @db.Uuid
  accessTokenCiphertext  String   @map("access_token_ciphertext")
  accessTokenIv          String   @map("access_token_iv")
  accessTokenAuthTag     String   @map("access_token_auth_tag")
  refreshTokenCiphertext String?  @map("refresh_token_ciphertext")
  refreshTokenIv         String?  @map("refresh_token_iv")
  refreshTokenAuthTag    String?  @map("refresh_token_auth_tag")
  keyVersion             String   @map("key_version")
  scopes                 String[] @default([])
  homeAccountId          String?  @map("home_account_id")
  expiresAt              DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, connectionId], map: "engagement_connection_tokens_tenant_connection_idx")
  @@map("engagement_connection_tokens")
}

model EngagementContact {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  clientId         String?  @map("client_id") @db.Uuid
  directoryEntryId String?  @map("directory_entry_id")
  fullName         String?  @map("full_name")
  email            String?  @db.Citext
  phone            String?
  organization     String?
  title            String?
  source           String   @default("manual")
  metadata         Json     @default("{}") @map("metadata_jsonb")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  attendees MeetingAttendee[]
  tasks     EngagementTask[]

  @@unique([tenantId, email], map: "engagement_contacts_tenant_email_key")
  @@index([tenantId, clientId], map: "engagement_contacts_tenant_client_idx")
  @@map("engagement_contacts")
}

model Meeting {
  id                 String           @id @default(uuid()) @db.Uuid
  tenantId           String           @map("tenant_id") @db.Uuid
  clientId           String?          @map("client_id") @db.Uuid
  connectionId       String?          @map("connection_id") @db.Uuid
  source             EngagementSource @default(manual)
  externalId         String?          @map("external_id")
  subject            String
  description        String?
  location           String?
  startsAt           DateTime         @map("starts_at") @db.Timestamptz(6)
  endsAt             DateTime         @map("ends_at") @db.Timestamptz(6)
  organizerEmail     String?          @map("organizer_email") @db.Citext
  organizerName      String?          @map("organizer_name")
  status             String           @default("scheduled")
  transcriptS3Key    String?          @map("transcript_s3_key")
  metadata           Json             @default("{}") @map("metadata_jsonb")
  raw                Json?            @map("raw_jsonb")
  associationScore   Float?           @map("association_score")
  associationReason  String?          @map("association_reason")
  associationSignals Json             @default("{}") @map("association_signals_jsonb")
  createdByUserId    String?          @map("created_by_user_id") @db.Uuid
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client          Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)
  connection      IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  attendees       MeetingAttendee[]
  attachments     EngagementAttachment[]
  notes           MeetingNote[]
  debriefs        MeetingDebrief[]
  preps           MeetingPrep[]
  tasks           EngagementTask[]
  outreachRecords OutreachRecord[]
  clioNotes       ClioNote[]

  @@unique([tenantId, source, externalId], map: "meetings_tenant_source_external_key")
  @@index([tenantId, startsAt], map: "meetings_tenant_starts_idx")
  @@index([tenantId, clientId, startsAt], map: "meetings_tenant_client_starts_idx")
  @@map("meetings")
}

model MeetingAttendee {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  meetingId      String   @map("meeting_id") @db.Uuid
  contactId      String?  @map("contact_id") @db.Uuid
  email          String?  @db.Citext
  name           String?
  role           String?
  responseStatus String?  @map("response_status")
  metadata       Json     @default("{}") @map("metadata_jsonb")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  meeting Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  contact EngagementContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([meetingId, email], map: "meeting_attendees_meeting_email_key")
  @@index([tenantId, email], map: "meeting_attendees_tenant_email_idx")
  @@map("meeting_attendees")
}

model MailThread {
  id                 String           @id @default(uuid()) @db.Uuid
  tenantId           String           @map("tenant_id") @db.Uuid
  clientId           String?          @map("client_id") @db.Uuid
  connectionId       String?          @map("connection_id") @db.Uuid
  source             EngagementSource @default(manual)
  externalId         String?          @map("external_id")
  subject            String
  snippet            String?
  participants       Json             @default("[]") @map("participants_jsonb")
  lastMessageAt      DateTime?        @map("last_message_at") @db.Timestamptz(6)
  status             String           @default("open")
  metadata           Json             @default("{}") @map("metadata_jsonb")
  raw                Json?            @map("raw_jsonb")
  associationScore   Float?           @map("association_score")
  associationReason  String?          @map("association_reason")
  associationSignals Json             @default("{}") @map("association_signals_jsonb")
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client     Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)
  connection IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  messages   MailMessage[]
  tasks      EngagementTask[]

  @@unique([tenantId, source, externalId], map: "mail_threads_tenant_source_external_key")
  @@index([tenantId, clientId, lastMessageAt], map: "mail_threads_tenant_client_last_idx")
  @@map("mail_threads")
}

model MailMessage {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  threadId       String           @map("thread_id") @db.Uuid
  connectionId   String?          @map("connection_id") @db.Uuid
  source         EngagementSource @default(manual)
  externalId     String?          @map("external_id")
  subject        String?
  fromEmail      String?          @map("from_email") @db.Citext
  fromName       String?          @map("from_name")
  toRecipients   Json             @default("[]") @map("to_recipients_jsonb")
  ccRecipients   Json             @default("[]") @map("cc_recipients_jsonb")
  bccRecipients  Json             @default("[]") @map("bcc_recipients_jsonb")
  sentAt         DateTime?        @map("sent_at") @db.Timestamptz(6)
  receivedAt     DateTime?        @map("received_at") @db.Timestamptz(6)
  bodyText       String?          @map("body_text")
  bodyHtmlS3Key  String?          @map("body_html_s3_key")
  hasAttachments Boolean          @default(false) @map("has_attachments")
  metadata       Json             @default("{}") @map("metadata_jsonb")
  raw            Json?            @map("raw_jsonb")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread      MailThread             @relation(fields: [threadId], references: [id], onDelete: Cascade)
  connection  IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  attachments EngagementAttachment[]

  @@unique([tenantId, source, externalId], map: "mail_messages_tenant_source_external_key")
  @@index([tenantId, fromEmail], map: "mail_messages_tenant_from_idx")
  @@index([tenantId, receivedAt], map: "mail_messages_tenant_received_idx")
  @@map("mail_messages")
}

model EngagementAttachment {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  clientId         String?  @map("client_id") @db.Uuid
  meetingId        String?  @map("meeting_id") @db.Uuid
  mailMessageId    String?  @map("mail_message_id") @db.Uuid
  fileName         String   @map("file_name")
  contentType      String   @map("content_type")
  byteSize         Int?     @map("byte_size")
  bucket           String
  s3Key            String   @map("s3_key")
  checksumSha256   String?  @map("checksum_sha256")
  source           String   @default("manual")
  uploadedByUserId String?  @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  meeting     Meeting?     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  mailMessage MailMessage? @relation(fields: [mailMessageId], references: [id], onDelete: Cascade)

  @@index([tenantId, clientId], map: "engagement_attachments_tenant_client_idx")
  @@index([tenantId, meetingId], map: "engagement_attachments_tenant_meeting_idx")
  @@index([tenantId, mailMessageId], map: "engagement_attachments_tenant_mail_message_idx")
  @@map("engagement_attachments")
}

model MeetingNote {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  meetingId      String   @map("meeting_id") @db.Uuid
  clientId       String?  @map("client_id") @db.Uuid
  authorUserId   String?  @map("author_user_id") @db.Uuid
  bodyCiphertext String   @map("body_ciphertext")
  iv             String
  authTag        String   @map("auth_tag")
  keyVersion     String?  @map("key_version")
  confidential   Boolean  @default(true)
  accessLevel    String   @default("tenant_admins_and_author") @map("access_level")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  client  Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  author  User?   @relation("MeetingNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, meetingId, createdAt], map: "meeting_notes_tenant_meeting_created_idx")
  @@map("meeting_notes")
}

model MeetingPrep {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  meetingId      String            @map("meeting_id") @db.Uuid
  clientId       String?           @map("client_id") @db.Uuid
  status         MeetingPrepStatus @default(generated)
