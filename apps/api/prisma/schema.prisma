  title       String    @db.Text
  date        DateTime? @db.Date
  authors     String[]  @default([])
  topics      String[]  @default([])
  summary     String?   @db.Text
  pdfUrl      String?   @map("pdf_url")
  htmlUrl     String?   @map("html_url")
  active      Boolean   @default(true) // false if report is archived/withdrawn
  syncedAt    DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([date])
  @@map("crs_report")
}

// ─────────────────────────────────────────────────────────────────────────
// RSS News & Intelligence articles (aggregated from multiple sources)
// GLOBAL table — no tenant_id, no RLS.
// Sources: Roll Call, The Hill, Axios, Politico, agency press, think tanks
// ─────────────────────────────────────────────────────────────────────────

model IntelArticle {
  id          String    @id @default(uuid())
  source      String    // "roll_call", "the_hill", "brookings", "whitehouse", etc.
  feedUrl     String?   @map("feed_url")
  title       String    @db.Text
  url         String    @unique
  author      String?
  publishedAt DateTime  @map("published_at") @db.Timestamptz(6)
  summary     String?   @db.Text
  categories  String[]  @default([])
  agencies    String[]  @default([]) // extracted agency names
  topics      String[]  @default([]) // extracted topic keywords
  syncedAt    DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([source, publishedAt])
  @@index([publishedAt])
  @@map("intel_article")
}

// ─────────────────────────────────────────────────────────────────────────
// Congressional Committee Activity (hearings, markups)
// GLOBAL table — no tenant_id, no RLS.
// Source: congress.gov API + committee RSS feeds
// ─────────────────────────────────────────────────────────────────────────

model CommitteeHearing {
  id            String    @id @default(uuid())
  chamber       String    // House, Senate, Joint
  committeeName String    @map("committee_name")
  committeeCode String?   @map("committee_code")
  title         String    @db.Text
  date          DateTime  @db.Date
  time          String?   // "10:00 AM"
  location      String?
  type          String?   // hearing, markup, meeting
  witnesses     String[]  @default([])
  url           String?
  syncedAt      DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([date])
  @@index([committeeName, date])
  @@map("committee_hearing")
}
