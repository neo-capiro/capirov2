  lastSyncedAt        DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@index([filingYear], map: "lda_filing_year_idx")
  @@index([dtPosted], map: "lda_filing_dt_posted_idx")
  @@index([clientId], map: "lda_filing_client_id_idx")
  @@index([registrantId], map: "lda_filing_registrant_id_idx")
  @@index([clientName], map: "lda_filing_client_name_idx")
  @@index([registrantName], map: "lda_filing_registrant_name_idx")
