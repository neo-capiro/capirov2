// ─────────────────────────────────────────────────────────────────────────
// Client-to-intelligence-source mapping (synthesis layer)
// GLOBAL table — links CRM clients to external intelligence identities.
// ─────────────────────────────────────────────────────────────────────────

model ClientIntelMapping {
  id           String   @id @default(uuid()) @db.Uuid
  clientId     String   @map("client_id") @db.Uuid
  source       String   // 'lda', 'contracting', 'lobby_intel', 'fec'
  externalId   String   @map("external_id")
  externalName String   @map("external_name")
  confidence   Float
  confirmed    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([clientId, source, externalId])
  @@index([clientId])
  @@index([source, externalId])
  @@map("client_intel_mapping")
}

// ─────────────────────────────────────────────────────────────────────────
// Cross-source change events (synthesis layer)
// GLOBAL table — detected changes from sync scripts.
// ─────────────────────────────────────────────────────────────────────────

model IntelligenceChange {
  id               String   @id @default(uuid()) @db.Uuid
  source           String
  changeType       String   @map("change_type")
  severity         String   @default("info")
  title            String
  description      String   @db.Text
  relatedClientIds String[] @map("related_client_ids") @db.Uuid
  relatedIssues    String[] @map("related_issues")
  data             Json     @default("{}")
  detectedAt       DateTime @default(now()) @map("detected_at") @db.Timestamptz(6)
  consumed         Boolean  @default(false)

  @@index([detectedAt(sort: Desc)])
  @@index([source, changeType])
  @@map("intelligence_change")
}

model RegulatoryDocket {
  id               String   @id @default(uuid())
  documentId       String   @unique @map("document_id")
  agencyId         String   @map("agency_id")
  docketId         String?  @map("docket_id")
  documentType     String   @map("document_type")
  title            String   @db.Text
  postedDate       DateTime? @map("posted_date")
  commentStartDate DateTime? @map("comment_start_date")
  commentEndDate   DateTime? @map("comment_end_date")
  frDocNum         String?  @map("fr_doc_num")
  subtype          String?
  withdrawn        Boolean  @default(false)
  lastModified     DateTime? @map("last_modified")
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@index([agencyId, postedDate])
  @@index([commentEndDate])
  @@index([documentType])
  @@map("regulatory_docket")
}

// ─────────────────────────────────────────────────────────────────────────
// AI Copilot Chat History
// Tenant-scoped. Filtered by tenantId in all application queries.
// ─────────────────────────────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id")
  role      String   // 'user' | 'assistant' | 'system'
  content   String   @db.Text
  metadata  Json?    // tool calls, context snapshot, intent, etc.
  sessionId String   @map("session_id")
