  issues           String[] @default([])
  years            Int[]    @default([])
  trajectory       String?  // exploding | declining | new | steady | null
  growthRate       Float?   @map("growth_rate")
  yearlySpend      Json     @default("[]") @map("yearly_spend_jsonb") // [{year, amount}]
  source           String   @default("openlobby")
  lastSyncedAt     DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)
  raw              Json     @default("{}") @map("raw_jsonb")

  @@index([name], map: "lobby_intel_name_idx")
  @@index([slug], map: "lobby_intel_slug_idx")
