// ─────────────────────────────────────────────────────────────────────────
// FEC Campaign Finance Data
//
// GLOBAL tables, shared across all tenants. No tenant_id, no RLS.
// Populated by apps/api/scripts/sync-fec.ts.
// Source: https://api.open.fec.gov/v1/, FEC campaign finance data.
// ─────────────────────────────────────────────────────────────────────────

model FecCommittee {
  // PACs and campaign committees from FEC API.
  id                 String   @id // committee_id like C00835926
  name               String
  committeeType      String?  @map("committee_type")
  designation        String?
  party              String?
  state              String?
  treasurerName      String?  @map("treasurer_name")
  totalReceipts      Decimal? @map("total_receipts") @db.Decimal(18, 2)
  totalDisbursements Decimal? @map("total_disbursements") @db.Decimal(18, 2)
  cashOnHand         Decimal? @map("cash_on_hand") @db.Decimal(18, 2)
  cycles             Int[]    @default([])
  lastSyncedAt       DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@index([name], map: "fec_committee_name_idx")
  @@map("fec_committee")
}

model FecContribution {
  // Individual/PAC contributions to candidates (Schedule A).
  id                    String    @id @default(uuid()) @db.Uuid
  committeeId           String    @map("committee_id")
  committeeName         String?   @map("committee_name")
  candidateId           String?   @map("candidate_id")
  candidateName         String?   @map("candidate_name")
  contributorName       String?   @map("contributor_name")
  contributorEmployer   String?   @map("contributor_employer")
  contributorOccupation String?   @map("contributor_occupation")
  amount                Decimal   @db.Decimal(18, 2)
  contributionDate      DateTime? @map("contribution_date") @db.Date
  receiptType           String?   @map("receipt_type")
  memoText              String?   @map("memo_text")
  state                 String?
  cycle                 Int
  lastSyncedAt          DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@unique([committeeId, candidateName, contributorEmployer, amount, cycle], map: "fec_contribution_dedup_key")
  @@index([committeeId], map: "fec_contribution_committee_id_idx")
  @@index([candidateName], map: "fec_contribution_candidate_name_idx")
  @@index([contributorEmployer], map: "fec_contribution_employer_idx")
  @@index([cycle], map: "fec_contribution_cycle_idx")
  @@map("fec_contribution")
}

model FecPacContribution {
  // Schedule B — disbursements BY a committee (PAC) TO candidates/committees.
  // This is the organization's OWN PAC giving — legally distinct from the
  // individual employer-linked contributions in FecContribution (Schedule A).
  // GLOBAL table (no tenant_id, no RLS); attributed to a client via a confirmed
  // ClientIntelMapping(source='fec_committee') linking client -> committeeId.
  id                   String    @id @default(uuid()) @db.Uuid
  committeeId          String    @map("committee_id") // the giving PAC committee
  committeeName        String?   @map("committee_name")
  recipientName        String?   @map("recipient_name") // candidate/committee receiving
  recipientCommitteeId String?   @map("recipient_committee_id")
  candidateId          String?   @map("candidate_id")
  candidateName        String?   @map("candidate_name")
  amount               Decimal   @db.Decimal(18, 2)
  disbursementDate     DateTime? @map("disbursement_date") @db.Date
  disbursementType     String?   @map("disbursement_type")
  memoText             String?   @map("memo_text")
  cycle                Int
  lastSyncedAt         DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@unique([committeeId, recipientName, amount, disbursementDate, cycle], map: "fec_pac_contribution_dedup_key")
  @@index([committeeId], map: "fec_pac_contribution_committee_id_idx")
  @@index([candidateName], map: "fec_pac_contribution_candidate_name_idx")
  @@index([cycle], map: "fec_pac_contribution_cycle_idx")
  @@map("fec_pac_contribution")
}

// ─────────────────────────────────────────────────────────────────────────
// Congress.gov Legislative Data
//
// GLOBAL tables, shared across all tenants. No tenant_id, no RLS.
// Populated by apps/api/scripts/sync-congress.ts.
// Source: https://api.congress.gov/v3/, Congress.gov API.
// ─────────────────────────────────────────────────────────────────────────

model CongressBill {
  // Bills from Congress.gov (118th and 119th Congress).
  id               String    @id // e.g. "119-hr-1234"
  congress         Int
  billType         String    @map("bill_type")
  billNumber       String    @map("bill_number")
  title            String
  introducedDate   DateTime? @map("introduced_date") @db.Date
  sponsorName      String?   @map("sponsor_name")
  sponsorState     String?   @map("sponsor_state")
  sponsorParty     String?   @map("sponsor_party")
  latestActionText String?   @map("latest_action_text")
  latestActionDate DateTime? @map("latest_action_date") @db.Date
  policyArea       String?   @map("policy_area")
  subjects         String[]  @default([])
  peCodes          String[]  @default([]) @map("pe_codes")
  committees       Json      @default("[]")
  cosponsorsCount  Int       @default(0) @map("cosponsors_count")
  originChamber    String?   @map("origin_chamber")
  updateDate       DateTime? @map("update_date") @db.Timestamptz(6)
  url              String?
  lastSyncedAt     DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  actions       CongressBillAction[]
  committeeRefs CongressBillCommittee[]
  subjectRefs   CongressBillSubject[]

  @@index([congress], map: "congress_bill_congress_idx")
  @@index([policyArea], map: "congress_bill_policy_area_idx")
  @@index([peCodes], map: "congress_bill_pe_codes_gin_idx", type: Gin)
  @@map("congress_bill")
}

/// Cached full bill text fetched from GovInfo, used by the bill PE-code extractor.
/// Global table — no tenant_id, no RLS. One row per bill (bill_id unique).
model BillText {
  id          String   @id @default(uuid()) @db.Uuid
  billId      String   @unique @map("bill_id")
  sourceUrl   String?  @map("source_url")
  textContent String   @map("text_content") @db.Text
  fetchedAt   DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)

  @@map("bill_text")
}

// ─────────────────────────────────────────────────────────────────────────
// Expanded Congress bill data (normalized)
// GLOBAL tables, no tenant_id, no RLS.
// ─────────────────────────────────────────────────────────────────────────

model CongressBillAction {
  id      String       @id @default(uuid())
  billId  String       @map("bill_id")
  date    DateTime
  text    String       @db.Text
  type    String?
  chamber String?
  bill    CongressBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId, date])
  @@map("congress_bill_action")
}

model CongressBillCommittee {
  id            String       @id @default(uuid())
  billId        String       @map("bill_id")
  committeeName String       @map("committee_name")
