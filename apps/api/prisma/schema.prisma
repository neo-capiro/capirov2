}

// ─────────────────────────────────────────────────────────────────────────
// BLS — Bureau of Labor Statistics time series data
// GLOBAL table — no tenant_id, no RLS.
// Source: api.bls.gov/publicAPI/v2/
// ─────────────────────────────────────────────────────────────────────────

model BlsSeries {
  id          String   @id // series_id e.g. "CES0000000001"
  title       String
  surveyName  String?  @map("survey_name")
  area        String?  // area code
  industry    String?  // industry code
  periodType  String   @map("period_type") // Monthly, Annual, Quarterly
  syncedAt    DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  dataPoints  BlsDataPoint[]

  @@map("bls_series")
}

model BlsDataPoint {
  id        String   @id @default(uuid())
  seriesId  String   @map("series_id")
  year      Int
  period    String   // M01-M12, Q01-Q05, A01
  value     Float
  footnotes String[] @default([])

  series    BlsSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, year, period])
  @@index([seriesId, year])
  @@map("bls_data_point")
}

// ─────────────────────────────────────────────────────────────────────────
// Census — ACS 5-Year data by congressional district
// GLOBAL table — no tenant_id, no RLS.
// Source: api.census.gov/data/2022/acs/acs5
// ─────────────────────────────────────────────────────────────────────────

model CensusDistrict {
  id                   String   @id // e.g. "119-CA-52" (congress-state-district)
  congress             Int      // 118, 119
  state                String   // 2-letter state code
  stateFips            String   @map("state_fips")
  district             String   // district number or "AL" for at-large
  totalPopulation      Int?     @map("total_population")
  medianHouseholdIncome Int?    @map("median_household_income")
  medianAge            Float?   @map("median_age")
  percentBachelorPlus  Float?   @map("percent_bachelor_plus") // % with bachelor's degree+
  percentPoverty       Float?   @map("percent_poverty")
  percentVeteran       Float?   @map("percent_veteran")
  percentUninsured     Float?   @map("percent_uninsured")
  laborForceSize       Int?     @map("labor_force_size")
  unemploymentRate     Float?   @map("unemployment_rate")
  topIndustries        Json     @default("[]") @map("top_industries") // [{name, employment, percent}]
  dataYear             Int      @map("data_year") // ACS vintage year
  syncedAt             DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([congress, state])
  @@index([state, district])
  @@map("census_district")
}

// ─────────────────────────────────────────────────────────────────────────
// BEA — Bureau of Economic Analysis GDP/industry data
// GLOBAL table — no tenant_id, no RLS.
// Source: apps.bea.gov/api/data/
// ─────────────────────────────────────────────────────────────────────────

model BeaData {
  id          String   @id @default(uuid())
  datasetName String   @map("dataset_name") // NIPA, Regional, Industry
  tableName   String   @map("table_name")
  lineNumber  Int?     @map("line_number")
  seriesCode  String?  @map("series_code")
  description String   @db.Text
  year        Int
  period      String   // Q1-Q4, Annual
  value       Float?
  units       String?  // Billions of dollars, Index, Percent
  geoFips     String?  @map("geo_fips") // state/county FIPS for regional
  syncedAt    DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@unique([datasetName, tableName, seriesCode, year, period, geoFips])
  @@index([datasetName, year])
  @@index([geoFips])
  @@map("bea_data")
}

// ─────────────────────────────────────────────────────────────────────────
// Grants.gov — Federal grant opportunities (NOFOs)
// GLOBAL table — no tenant_id, no RLS.
// Source: api.grants.gov/v1/api/search2
// ─────────────────────────────────────────────────────────────────────────

model FederalGrant {
  id                String    @id // opportunity ID from Grants.gov
  title             String    @db.Text
  agency            String    // awarding agency
  subAgency         String?   @map("sub_agency")
  opportunityNumber String?   @map("opportunity_number")
  category          String?   // Discretionary, Mandatory, etc.
  fundingInstrument String?   @map("funding_instrument") // Grant, Cooperative Agreement
  eligibility       String[]  @default([]) // eligible applicant types
  cfdaNumbers       String[]  @default([]) @map("cfda_numbers")
  awardCeiling      Float?    @map("award_ceiling")
  awardFloor        Float?    @map("award_floor")
  estimatedFunding  Float?    @map("estimated_funding")
  expectedAwards    Int?      @map("expected_awards")
  openDate          DateTime? @map("open_date") @db.Date
  closeDate         DateTime? @map("close_date") @db.Date
  status            String?   // posted, closed, archived, forecasted
  description       String?   @db.Text
  url               String?
  syncedAt          DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([agency])
  @@index([closeDate])
  @@index([status])
  @@map("federal_grant")
}

// ─────────────────────────────────────────────────────────────────────────
