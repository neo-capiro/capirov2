  scoreBreakdown   Json      @default("{}") @map("score_breakdown_jsonb")
  status           String    @default("open") @db.VarChar(20) // open | confirmed | rejected
  resolvedByUserId String?   @map("resolved_by_user_id") @db.Uuid
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz(6)
  decisionNotes    String?   @map("decision_notes") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([personId, peCode], map: "program_element_person_candidate_person_pe_key")
  @@index([status], map: "program_element_person_candidate_status_idx")
  @@index([peCode], map: "program_element_person_candidate_pe_code_idx")
  @@map("program_element_person_candidate")
}

model ConferenceProbability {
