// Proposed person -> Program Element links awaiting human review. Generated by the
// PE-person matcher (org/title tokens vs PE + project titles). NEVER auto-applied:
// a reviewer confirms a candidate, which then sets acquisition_personnel.pe_primary.
// Mirrors AcquisitionPersonnelMergeCandidate review-queue conventions. Global table.
model ProgramElementPersonCandidate {
  id               String    @id @default(uuid()) @db.Uuid
  personId         String    @map("person_id") @db.Uuid
  peCode           String    @map("pe_code") @db.VarChar(16)
  score            Float
