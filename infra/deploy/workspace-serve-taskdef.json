{
  "family": "capiro-dev-workspace",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": { "cpuArchitecture": "ARM64", "operatingSystemFamily": "LINUX" },
  "executionRoleArn": "arn:aws:iam::967807252336:role/Capiro-dev-Compute-ApiTaskDefExecutionRoleE6ABB053-YlEDKuUPHjLg",
  "taskRoleArn": "arn:aws:iam::967807252336:role/Capiro-dev-Compute-ApiTaskRole12FAD4A7-szq3QeeZJSCQ",
  "containerDefinitions": [
    {
      "name": "workspace",
      "image": "967807252336.dkr.ecr.us-east-1.amazonaws.com/capiro/dev/workspace:latest",
      "essential": true,
      "command": ["serve"],
      "portMappings": [{ "containerPort": 4200, "protocol": "tcp" }],
      "environment": [
        { "name": "DB_NAME", "value": "capiro" },
        { "name": "NODE_ENV", "value": "production" },
        { "name": "WORKSPACE_PORT", "value": "4200" },
        { "name": "WORKSPACE_MODEL", "value": "claude-sonnet-4-6" },
        { "name": "WORKSPACE_LOG_LEVEL", "value": "debug" },
        { "name": "CLERK_JWT_ISSUER", "value": "https://clerk.app.capiro.ai" },
        { "name": "WEB_ORIGIN", "value": "https://app.capiro.ai" }
      ],
      "secrets": [
        { "name": "CLERK_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967807252336:secret:/capiro/dev/clerk/secret-key-FT67tM" },
        { "name": "DB_HOST", "valueFrom": "arn:aws:secretsmanager:us-east-1:967807252336:secret:/capiro/dev/aurora/master-P4z1Vo:host::" },
        { "name": "DB_PORT", "valueFrom": "arn:aws:secretsmanager:us-east-1:967807252336:secret:/capiro/dev/aurora/master-P4z1Vo:port::" },
        { "name": "DB_USER", "valueFrom": "arn:aws:secretsmanager:us-east-1:967807252336:secret:/capiro/dev/aurora/app-zNPtsU:username::" },
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-east-1:967807252336:secret:/capiro/dev/aurora/app-zNPtsU:password::" },
        { "name": "OPENAI_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967807252336:secret:capiro/dev/openai-api-key-7nAmib" },
        { "name": "ANTHROPIC_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967807252336:secret:capiro/dev/anthropic-api-key-3nhKhF" },
        { "name": "AI_CREDENTIAL_ENCRYPTION_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967807252336:secret:capiro/dev/ai-credential-encryption-key-ohnjaH" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://127.0.0.1:4200/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/capiro/dev/api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "workspace"
        }
      }
    }
  ]
}
