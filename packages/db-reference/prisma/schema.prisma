model ProgramElementPerformer {
  id                  String   @id @default(uuid()) @db.Uuid
  peCode              String   @map("pe_code") @db.VarChar(16)
  /// Company name exactly as printed in the exhibit (e.g. 'LOCKHEED MARTIN CORPORATION').
  performer           String
  /// Uppercased/punctuation-stripped name for joins/dedup (e.g. 'LOCKHEED MARTIN CORP').
  performerNormalized String   @map("performer_normalized")
  /// Performing location as printed (state code 'AL', 'Various', city, or country).
  /// NOT NULL ('' when absent) so the natural-key unique index is deterministic
  /// (Postgres treats NULLs as distinct, which would break idempotent upserts).
  location            String   @default("") @map("location")
  /// Contract method & type token ('SS/IDIQ','C/CPAF','MIPR',...). '' when blank/Various.
  contractMethod      String   @default("") @map("contract_method")
  /// Cost-category item label from the exhibit row (e.g. 'THAAD Development - Capability').
  costCategory        String   @default("") @map("cost_category")
  /// Total contract cost in $M as printed (TotalCost column). Null when not stated.
  totalCostM          Decimal? @map("total_cost_m") @db.Decimal(18, 3)
  /// R-3 table family this came from: 'product_development' | 'support' | 'management_services'.
  tableType           String?  @map("table_type")
  /// Project (R-2A) code/name when the table is under a specific project, else null.
  projectCode         String?  @map("project_code")
  projectName         String?  @map("project_name")
  fy                  Int
  sourceUrl           String   @map("source_url")
  pageNumber          Int      @map("page_number")
  /// Publishing component for provenance label (e.g. 'DoD Comptroller (Navy)').
  publisher           String?
  /// True when the performer is a real named company (has a legal suffix / not 'Various'/
  /// 'TBD'/government-internal MIPR). Lets the read path surface only real primes by default.
  isNamedCompany      Boolean  @default(true) @map("is_named_company")
  source              String   @default("comptroller_jbook_r3")
  confidence          Float    @default(0.95)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSyncedAt        DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)
  // Registry link (Step 0.1): the fingerprinted source file this performer row came from.
  sourceDocumentId    String?  @map("source_document_id") @db.Uuid

  programElement ProgramElement  @relation(fields: [peCode], references: [peCode], onDelete: Cascade)
  sourceDocument SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Natural key: same prime can appear under different cost categories / projects / methods.
  @@unique([peCode, performerNormalized, location, contractMethod, costCategory, fy], map: "program_element_performer_natural_key")
  @@index([peCode], map: "program_element_performer_pe_code_idx")
  @@index([performerNormalized], map: "program_element_performer_norm_idx")
  @@index([isNamedCompany], map: "program_element_performer_named_idx")
  @@index([sourceDocumentId], map: "program_element_performer_source_document_idx")
  @@map("program_element_performer")
}

