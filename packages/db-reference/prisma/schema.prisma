model ProgramElementDelta {
  id                 String    @id @default(uuid()) @db.Uuid
  peCode             String    @map("pe_code") @db.VarChar(16)
  assertedFy         Int       @map("asserted_fy")
  deltaType          String    @map("delta_type")
  fromRef            String?   @map("from_ref")
  toRef              String?   @map("to_ref")
  amountFrom         Decimal?  @map("amount_from") @db.Decimal(14, 2)
  amountTo           Decimal?  @map("amount_to") @db.Decimal(14, 2)
  deltaAbs           Decimal?  @map("delta_abs") @db.Decimal(14, 2)
  deltaPct           Float?    @map("delta_pct")
  // Exact-copy change-summary narrative (Step 1.5 attaches it; never generated).
  explanation        String?   @db.Text
  // Source rows/pages used to compute this delta (provenance for the "evidence chip").
  evidence           Json      @default("{}") @map("evidence_jsonb")
  materialityScore   Float     @map("materiality_score")
  materialityFactors Json      @default("{}") @map("materiality_factors_jsonb")
  computedAt         DateTime  @default(now()) @map("computed_at") @db.Timestamptz(6)
  // Set on the OLD row when a recompute supersedes it; NULL = current live delta.
  supersededAt       DateTime? @map("superseded_at") @db.Timestamptz(6)

  programElement ProgramElement @relation(fields: [peCode], references: [peCode], onDelete: Cascade)

  // NOTE: the natural-key uniqueness is enforced by a PARTIAL functional unique index
  // (WHERE superseded_at IS NULL, COALESCE-ing the nullable from/to refs) created in
  // the migration raw SQL — Prisma 5 cannot express partial/functional unique indexes,
  // so this is a plain compound index here (kept queryable) and the migration adds the
  // partial unique constraint. Latest-wins: superseded rows share the natural key.
  @@index([peCode, assertedFy, deltaType, fromRef, toRef], map: "program_element_delta_natural_key_idx")
  @@index([peCode, assertedFy], map: "program_element_delta_pe_fy_idx")
  @@index([deltaType], map: "program_element_delta_type_idx")
  @@index([materialityScore(sort: Desc)], map: "program_element_delta_score_idx")
  @@index([supersededAt], map: "program_element_delta_superseded_idx")
  @@map("program_element_delta")
}

