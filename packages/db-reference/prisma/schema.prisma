// READ-ONLY schema for the capiro-dev reference/bulk datasets.
// prod-os-capiro NEVER migrates or writes these tables. Generated client is query-only.
// `prisma migrate` MUST NOT be run against this schema/datasource.

// Capiro identity / tenancy core schema.
// Scope: tenants, users, tenant_memberships, clerk_events, audit_logs.
// All tenant-scoped tables carry tenant_id NOT NULL and are protected by
// Postgres Row-Level Security policies created in the SQL migration.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/reference-client"
}

datasource db {
  provider = "postgresql"
  url      = env("REFERENCE_DATABASE_URL")
}

model AcquisitionPersonnel {
  id               String    @id @default(uuid()) @db.Uuid
  fullName         String    @map("full_name")
  nameKey          String    @map("name_key")
  service          String?   @db.VarChar(8)
  organization     String?
  title            String?
  role             String?
  programOfRecord  String?   @map("program_of_record")
  pePrimary        String?   @map("pe_primary") @db.VarChar(16)
  peSecondary      String[]  @default([]) @map("pe_secondary")
  emailDomain      String?   @map("email_domain")
  publicProfileUrl String?   @map("public_profile_url")
  confidence       Float     @default(0.5)
  status           String    @default("active") @db.VarChar(16)
  // Soft-supersede marker. Set by reconcile-personnel-supersede when a person's
  // only provenance is a deprecated one-time directory load (e.g. the old
  // stanford_dow_* spreadsheet) and no current source re-asserts them. Reads
  // exclude supersededAt IS NOT NULL by default. Reversible (set back to null).
  // Distinct from status='departed', which is a real-world departure signal.
  supersededAt     DateTime? @map("superseded_at") @db.Timestamptz(6)
  supersededReason String?   @map("superseded_reason")
  firstSeenAt      DateTime  @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  metadata         Json      @default("{}") @map("metadata_jsonb")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  sources AcquisitionPersonnelSource[]
  roles   PersonRole[]

  @@index([pePrimary], map: "acquisition_personnel_pe_primary_idx")
  @@index([nameKey], map: "acquisition_personnel_name_key_idx")
  @@index([service, organization], map: "acquisition_personnel_service_org_idx")
  @@index([status], map: "acquisition_personnel_status_idx")
  @@index([supersededAt], map: "acquisition_personnel_superseded_at_idx")
  @@map("acquisition_personnel")
}

model AcquisitionPersonnelMergeCandidate {
  id                String    @id @default(uuid()) @db.Uuid
  primaryPersonId   String    @map("primary_person_id") @db.Uuid
  secondaryPersonId String    @map("secondary_person_id") @db.Uuid
  similarityScore   Float     @map("similarity_score")
  scoreBreakdown    Json      @default("{}") @map("score_breakdown_jsonb")
  status            String    @default("open") @db.VarChar(20)
  resolvedByUserId  String?   @map("resolved_by_user_id") @db.Uuid
  resolvedAt        DateTime? @map("resolved_at") @db.Timestamptz(6)
  decisionNotes     String?   @map("decision_notes") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status], map: "acquisition_personnel_merge_candidate_status_idx")
  @@map("acquisition_personnel_merge_candidate")
}

model AcquisitionPersonnelQuarantine {
  id            String   @id @default(uuid()) @db.Uuid
  rawRecord     Json     @map("raw_record_jsonb")
  reason        String
  source        String
  quarantinedAt DateTime @default(now()) @map("quarantined_at") @db.Timestamptz(6)

  @@map("acquisition_personnel_quarantine")
}

model AcquisitionPersonnelSource {
  id         String   @id @default(uuid()) @db.Uuid
  personId   String   @map("person_id") @db.Uuid
  source     String   @db.VarChar(64)
  sourceUrl  String?  @map("source_url")
  snippet    String?  @db.Text
  observedAt DateTime @map("observed_at") @db.Timestamptz(6)
  confidence Float
  metadata   Json     @default("{}") @map("metadata_jsonb")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  person AcquisitionPersonnel @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId, observedAt], map: "acquisition_personnel_source_person_observed_idx")
  @@index([source], map: "acquisition_personnel_source_source_idx")
  @@map("acquisition_personnel_source")
}

model BeaData {
  id          String   @id @default(uuid())
  datasetName String   @map("dataset_name") // NIPA, Regional, Industry
  tableName   String   @map("table_name")
  lineNumber  Int?     @map("line_number")
  seriesCode  String?  @map("series_code")
  description String   @db.Text
  year        Int
  period      String // Q1-Q4, Annual
  value       Float?
  units       String? // Billions of dollars, Index, Percent
  geoFips     String?  @map("geo_fips") // state/county FIPS for regional
  syncedAt    DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@unique([datasetName, tableName, seriesCode, year, period, geoFips])
  @@index([datasetName, year])
  @@index([geoFips])
  @@map("bea_data")
}

model BillText {
  id          String   @id @default(uuid()) @db.Uuid
  billId      String   @unique @map("bill_id")
  sourceUrl   String?  @map("source_url")
  textContent String   @map("text_content") @db.Text
  fetchedAt   DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)

  @@map("bill_text")
}

model BlsDataPoint {
  id        String   @id @default(uuid())
  seriesId  String   @map("series_id")
  year      Int
  period    String // M01-M12, Q01-Q05, A01
  value     Float
  footnotes String[] @default([])

  series BlsSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, year, period])
  @@index([seriesId, year])
  @@map("bls_data_point")
}

model BlsSeries {
  id         String   @id // series_id e.g. "CES0000000001"
  title      String
  surveyName String?  @map("survey_name")
  area       String? // area code
  industry   String? // industry code
  periodType String   @map("period_type") // Monthly, Annual, Quarterly
  syncedAt   DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  dataPoints BlsDataPoint[]

  @@map("bls_series")
}

model CensusDistrict {
  id                    String   @id // e.g. "119-CA-52" (congress-state-district)
  congress              Int // 118, 119
  state                 String // 2-letter state code
  stateFips             String   @map("state_fips")
  district              String // district number or "AL" for at-large
  totalPopulation       Int?     @map("total_population")
  medianHouseholdIncome Int?     @map("median_household_income")
  medianAge             Float?   @map("median_age")
  percentBachelorPlus   Float?   @map("percent_bachelor_plus") // % with bachelor's degree+
  percentPoverty        Float?   @map("percent_poverty")
  percentVeteran        Float?   @map("percent_veteran")
  percentUninsured      Float?   @map("percent_uninsured")
  laborForceSize        Int?     @map("labor_force_size")
  unemploymentRate      Float?   @map("unemployment_rate")
  topIndustries         Json     @default("[]") @map("top_industries") // [{name, employment, percent}]
  dataYear              Int      @map("data_year") // ACS vintage year
  syncedAt              DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([congress, state])
  @@index([state, district])
  @@map("census_district")
}

model ClerkEvent {
  id          String    @id @default(uuid()) @db.Uuid
  eventId     String    @unique @map("event_id")
  eventType   String    @map("event_type")
  payload     Json      @map("payload_jsonb")
  receivedAt  DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  error       String?

  @@index([eventType], map: "clerk_events_event_type_idx")
  @@map("clerk_events")
}

model CommitteeHearing {
  id            String   @id @default(uuid())
  chamber       String // House, Senate, Joint
  committeeName String   @map("committee_name")
  committeeCode String?  @map("committee_code")
  title         String   @db.Text
  date          DateTime @db.Date
  time          String? // "10:00 AM"
  location      String?
  type          String? // hearing, markup, meeting
  witnesses     String[] @default([])
  url           String?
  syncedAt      DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([date])
  @@index([committeeName, date])
  @@map("committee_hearing")
}

model CommitteeReportProvision {
  id               String   @id @default(uuid()) @db.Uuid
  sourceDocumentId String?  @map("source_document_id") @db.Uuid
  /// Issuing committee short code: 'HASC' | 'SASC' | 'HAC-D' | 'SAC-D' | 'CONF'.
  committee        String   @db.VarChar(16)
  fy               Int
  /// The provision's heading / item title as it appears in the report.
  heading          String   @db.Text
  /// The full provision language (verbatim).
  text             String   @db.Text
  pageStart        Int?     @map("page_start")
  pageEnd          Int?     @map("page_end")
  /// Deterministic classifier output (see provision-action-classifier): 'directs_briefing'
  /// | 'directs_report' | 'adds' | 'cuts' | 'transfers' | 'restricts' | 'encourages' |
  /// 'expresses_concern'. Null when the language is ambiguous / unclassified.
  actionType       String?  @map("action_type") @db.VarChar(24)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  sourceDocument SourceDocument?   @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  links          ProvisionPeLink[]

  @@index([committee, fy], map: "committee_report_provision_committee_fy_idx")
  @@index([actionType], map: "committee_report_provision_action_type_idx")
  @@index([sourceDocumentId], map: "committee_report_provision_source_document_idx")
  @@map("committee_report_provision")
}

model ConferenceProbability {
  peCode       String   @map("pe_code") @db.VarChar(16)
  fy           Int
  predicted    Decimal  @db.Decimal(14, 4)
  ciLow        Decimal  @map("ci_low") @db.Decimal(14, 4)
  ciHigh       Decimal  @map("ci_high") @db.Decimal(14, 4)
  confidence   Decimal  @db.Decimal(6, 4)
  modelVersion String   @map("model_version")
  computedAt   DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)

  programElement ProgramElement @relation(fields: [peCode], references: [peCode], onDelete: Cascade)

  @@id([peCode, fy])
  @@index([fy], map: "conference_probability_fy_idx")
  @@index([modelVersion], map: "conference_probability_model_version_idx")
  @@map("conference_probability")
}

model CongressBill {
  // Bills from Congress.gov (118th and 119th Congress).
  id               String    @id // e.g. "119-hr-1234"
  congress         Int
  billType         String    @map("bill_type")
  billNumber       String    @map("bill_number")
  title            String
  introducedDate   DateTime? @map("introduced_date") @db.Date
  sponsorName      String?   @map("sponsor_name")
  sponsorState     String?   @map("sponsor_state")
  sponsorParty     String?   @map("sponsor_party")
  latestActionText String?   @map("latest_action_text")
  latestActionDate DateTime? @map("latest_action_date") @db.Date
  policyArea       String?   @map("policy_area")
  subjects         String[]  @default([])
  peCodes          String[]  @default([]) @map("pe_codes")
  committees       Json      @default("[]")
  cosponsorsCount  Int       @default(0) @map("cosponsors_count")
  originChamber    String?   @map("origin_chamber")
  updateDate       DateTime? @map("update_date") @db.Timestamptz(6)
  url              String?
  lastSyncedAt     DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  actions       CongressBillAction[]
  committeeRefs CongressBillCommittee[]
  subjectRefs   CongressBillSubject[]

  @@index([congress], map: "congress_bill_congress_idx")
  @@index([policyArea], map: "congress_bill_policy_area_idx")
  @@index([peCodes], map: "congress_bill_pe_codes_gin_idx", type: Gin)
  @@map("congress_bill")
}

model CongressBillAction {
  id      String       @id @default(uuid())
  billId  String       @map("bill_id")
  date    DateTime
  text    String       @db.Text
  type    String?
  chamber String?
  bill    CongressBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId, date])
  @@map("congress_bill_action")
}

model CongressBillCommittee {
  id            String       @id @default(uuid())
  billId        String       @map("bill_id")
  committeeName String       @map("committee_name")
  committeeCode String?      @map("committee_code")
  chamber       String?
  bill          CongressBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([committeeCode])
  @@map("congress_bill_committee")
}

model CongressBillSubject {
  id     String       @id @default(uuid())
  billId String       @map("bill_id")
  name   String
  bill   CongressBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([name])
  @@map("congress_bill_subject")
}

model CrsReport {
  id       String    @id // CRS report number e.g. "R47650"
  title    String    @db.Text
  date     DateTime? @db.Date
  authors  String[]  @default([])
  topics   String[]  @default([])
  summary  String?   @db.Text
  pdfUrl   String?   @map("pdf_url")
  htmlUrl  String?   @map("html_url")
  active   Boolean   @default(true) // false if report is archived/withdrawn
  syncedAt DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([date])
  @@map("crs_report")
}

model DemoRequest {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @db.Citext
  company   String
  role      String?
  message   String?  @db.Text
  source    String?
  status    String   @default("new")
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "demo_requests_created_idx")
  @@index([email, createdAt(sort: Desc)], map: "demo_requests_email_created_idx")
  @@map("demo_requests")
}

model FaraRegistration {
  id                 String    @id @default(uuid())
  registrationNumber String    @unique @map("registration_number")
  registrantName     String    @map("registrant_name")
  foreignPrincipal   String    @map("foreign_principal")
  country            String?
  status             String? // Active, Terminated
  registrationDate   DateTime? @map("registration_date") @db.Date
  terminationDate    DateTime? @map("termination_date") @db.Date
  address            String?
  state              String?
  description        String?   @db.Text
  syncedAt           DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([registrantName])
  @@index([foreignPrincipal])
  @@index([country])
  @@map("fara_registration")
}

model FecCommittee {
  // PACs and campaign committees from FEC API.
  id                 String   @id // committee_id like C00835926
  name               String
  committeeType      String?  @map("committee_type")
  designation        String?
  party              String?
  state              String?
  treasurerName      String?  @map("treasurer_name")
  totalReceipts      Decimal? @map("total_receipts") @db.Decimal(18, 2)
  totalDisbursements Decimal? @map("total_disbursements") @db.Decimal(18, 2)
  cashOnHand         Decimal? @map("cash_on_hand") @db.Decimal(18, 2)
  cycles             Int[]    @default([])
  lastSyncedAt       DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@index([name], map: "fec_committee_name_idx")
  @@map("fec_committee")
}

model FecContribution {
  // Individual/PAC contributions to candidates (Schedule A).
  id                    String    @id @default(uuid()) @db.Uuid
  committeeId           String    @map("committee_id")
  committeeName         String?   @map("committee_name")
  candidateId           String?   @map("candidate_id")
  candidateName         String?   @map("candidate_name")
  contributorName       String?   @map("contributor_name")
  contributorEmployer   String?   @map("contributor_employer")
  contributorOccupation String?   @map("contributor_occupation")
  amount                Decimal   @db.Decimal(18, 2)
  contributionDate      DateTime? @map("contribution_date") @db.Date
  receiptType           String?   @map("receipt_type")
  memoText              String?   @map("memo_text")
  state                 String?
  cycle                 Int
  lastSyncedAt          DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@unique([committeeId, candidateName, contributorEmployer, amount, cycle], map: "fec_contribution_dedup_key")
  @@index([committeeId], map: "fec_contribution_committee_id_idx")
  @@index([candidateName], map: "fec_contribution_candidate_name_idx")
  @@index([contributorEmployer], map: "fec_contribution_employer_idx")
  @@index([cycle], map: "fec_contribution_cycle_idx")
  @@map("fec_contribution")
}

model FecPacContribution {
  // Schedule B — disbursements BY a committee (PAC) TO candidates/committees.
  // This is the organization's OWN PAC giving — legally distinct from the
  // individual employer-linked contributions in FecContribution (Schedule A).
  // GLOBAL table (no tenant_id, no RLS); attributed to a client via a confirmed
  // ClientIntelMapping(source='fec_committee') linking client -> committeeId.
  id                   String    @id @default(uuid()) @db.Uuid
  committeeId          String    @map("committee_id") // the giving PAC committee
  committeeName        String?   @map("committee_name")
  recipientName        String?   @map("recipient_name") // candidate/committee receiving
  recipientCommitteeId String?   @map("recipient_committee_id")
  candidateId          String?   @map("candidate_id")
  candidateName        String?   @map("candidate_name")
  amount               Decimal   @db.Decimal(18, 2)
  disbursementDate     DateTime? @map("disbursement_date") @db.Date
  disbursementType     String?   @map("disbursement_type")
  memoText             String?   @map("memo_text")
  cycle                Int
  lastSyncedAt         DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@unique([committeeId, recipientName, amount, disbursementDate, cycle], map: "fec_pac_contribution_dedup_key")
  @@index([committeeId], map: "fec_pac_contribution_committee_id_idx")
  @@index([candidateName], map: "fec_pac_contribution_candidate_name_idx")
  @@index([cycle], map: "fec_pac_contribution_cycle_idx")
  @@map("fec_pac_contribution")
}

model FederalAgency {
  // 97 federal agencies with budget authority + top contractors.
  slug            String   @id
  name            String
  abbreviation    String?
  code            String?
  displayName     String?  @map("display_name")
  budgetAuthority Decimal? @map("budget_authority") @db.Decimal(18, 2)
  obligated       Decimal? @db.Decimal(18, 2)
  outlays         Decimal? @db.Decimal(18, 2)
  pctOfTotal      Float?   @map("pct_of_total")
  pctOfBudget     Float?   @map("pct_of_budget")
  pctContracts    Float?   @map("pct_contracts")
  costPerAmerican Float?   @map("cost_per_american")
  rankBySpending  Int?     @map("rank_by_spending")
  contractsTotal  Decimal? @map("contracts_total") @db.Decimal(18, 2)
  grantsTotal     Decimal? @map("grants_total") @db.Decimal(18, 2)
  yearlyBudget    Json     @default("[]") @map("yearly_budget_jsonb")
  topContractors  Json     @default("[]") @map("top_contractors_jsonb")
  lastSyncedAt    DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)

  @@index([name], map: "federal_agency_name_idx")
  @@map("federal_agency")
}

model FederalAward {
  id                             String    @id @default(uuid()) @db.Uuid
  // USAspending generated_unique_award_id — stable idempotency key.
  awardUniqueId                  String    @unique @map("award_unique_id")
  piid                           String?
  fain                           String?
  awardingAgency                 String?   @map("awarding_agency")
  awardingSubTier                String?   @map("awarding_sub_tier")
  contractorName                 String?   @map("contractor_name")
  recipientUei                   String?   @map("recipient_uei")
  amount                         Decimal?  @db.Decimal(18, 2)
  description                    String?   @db.Text
  peCode                         String?   @map("pe_code") @db.VarChar(16)
  // How pe_code was resolved, for provenance/auditing and honest UI labeling.
  // Null when pe_code is null. Values: 'description_regex' (legacy text match),
  // 'dod_acquisition_program' (linked via the contract's DoD acquisition / MDAP
  // code through the reviewed program_element_acquisition_program map). Lets the
  // contractor panel state HOW a contractor was tied to a PE rather than implying
  // a precision the source does not have.
  peCodeSource                   String?   @map("pe_code_source")
  // ── USAspending File C (financial_accounts_by_awards) funding crosswalk ──────────
  // Populated by enrich-award-pe-tas from /api/v2/awards/funding/. The Treasury
  // Account Symbol + Program Activity are the federal mechanism that ties an award
  // to the appropriation account / program activity it was funded from. We store the
  // dominant (largest-obligation) TAS+PA for display + the PE crosswalk. PE attribution
  // from TAS+PA is intentionally LOWER precision than the R-3 named-prime link (one
  // account/PA funds many PEs), so peCodeConfidence + peCodeCandidateCount make the
  // ambiguity explicit and the UI never implies a false 1:1.
  fundingTas                     String?   @map("funding_tas") // e.g. '057-3600' (federal_account) or full TAS label
  fundingTasTitle                String?   @map("funding_tas_title") // e.g. 'RDT&E, Air Force'
  programActivityCode            String?   @map("program_activity_code") // e.g. '0001'
  programActivityName            String?   @map("program_activity_name") // e.g. 'BASIC RESEARCH'
  fundingFy                      Int?      @map("funding_fy") // reporting fiscal year of the dominant File C row
  // 0..1 confidence of the pe_code attribution. 1.0 only when UEI-confirmed against an
  // R-3 named prime; ~0.5 when account+PA+FY resolve to a single PE; lower when ambiguous.
  peCodeConfidence               Float?    @map("pe_code_confidence")
  // How many distinct PEs the award's (account + program activity + FY) could map to.
  // 1 = unambiguous; >1 = the UI shows "funded via <account> (N programs)" not a single PE.
  peCodeCandidateCount           Int?      @map("pe_code_candidate_count")
  // When peCodeSource='uei_confirmed_r3_prime', the matched performer row id (audit trail).
  matchedPerformerId             String?   @map("matched_performer_id") @db.Uuid
  // DoD Major Defense Acquisition Program (MDAP) attribution straight off the
  // contract record (USAspending latest_transaction_contract_data). Always present
  // on contracts; '000'/'NONE' for services & non-program awards. This is the
  // zero-inference link between a contractor and a weapons program — e.g.
  // '198'/'F-35', '516'/'SSN 774'. PE attribution is derived from these via the
  // program_element_acquisition_program map, NOT fabricated.
  dodAcqProgramCode              String?   @map("dod_acq_program_code")
  dodAcqProgramName              String?   @map("dod_acq_program_name")
  // Place of performance (where the work happens) — primary signal for district
  // nexus. Recipient location (where the company is HQ'd) kept as a fallback.
  // Two-letter state + congressional-district number as text ('02', 'AL'); null
  // when USAspending omits it. Populated by sync-federal-award location fields.
  popState                       String?   @map("pop_state")
  popCongressionalDistrict       String?   @map("pop_congressional_district")
  recipientState                 String?   @map("recipient_state")
  recipientCongressionalDistrict String?   @map("recipient_congressional_district")
