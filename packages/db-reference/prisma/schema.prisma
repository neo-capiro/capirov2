  programId      String?   @map("program_id") @db.Uuid
  roleTitle      String    @map("role_title")
  /// 'peo' | 'pm' | 'deputy' | 'chief_engineer' | 'contracting_officer' | 'staff' | 'other'
  roleType       String    @map("role_type") @db.VarChar(24)
  source         String    @db.VarChar(64)
  sourceUrl      String?   @map("source_url")
  sourceQuote    String?   @map("source_quote") @db.Text
  observedAt     DateTime  @map("observed_at") @db.Timestamptz(6)
  effectiveStart DateTime? @map("effective_start") @db.Timestamptz(6)
  effectiveEnd   DateTime? @map("effective_end") @db.Timestamptz(6)
  confidence     Float     @default(0.5)
  /// 'accepted' | 'candidate' | 'quarantined'
  reviewStatus   String    @default("candidate") @map("review_status") @db.VarChar(20)
  /// 'lobbying_contact' | 'program_ownership_context' | 'official_procurement_poc' |
  /// 'internal_owner' | 'relationship_owner' | 'do_not_contact_procurement_sensitive' |
  /// 'candidate' | 'quarantined'. Set by the contact-use policy module.
  contactUse     String    @map("contact_use") @db.VarChar(40)
  staleAt        DateTime? @map("stale_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  person  AcquisitionPersonnel @relation(fields: [personId], references: [id], onDelete: Cascade)
  office  ProgramOffice?       @relation(fields: [officeId], references: [id], onDelete: SetNull)
  program Program?             @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@index([personId], map: "person_role_person_id_idx")
  @@index([officeId], map: "person_role_office_id_idx")
  @@index([programId], map: "person_role_program_id_idx")
  @@index([reviewStatus], map: "person_role_review_status_idx")
  @@index([contactUse], map: "person_role_contact_use_idx")
  @@map("person_role")
}

