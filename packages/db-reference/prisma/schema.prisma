model PeProgramMatch {
  id               String    @id @default(uuid()) @db.Uuid
  peCode           String    @map("pe_code") @db.VarChar(16)
  /// Project (R-2A) code within the PE when the match is project-level, else null.
  projectCode      String?   @map("project_code") @db.VarChar(8)
  programId        String    @map("program_id") @db.Uuid
  score            Float
  /// 'exact_pe_number' | 'exact_project_title' | 'r2a_office_named' |
  /// 'other_funding_link' | 'official_office_page' | 'sar_msar' | 'sam_match' |
  /// 'award_match' | 'press_release' | 'news_only' | 'mdap_curated' (seed).
  evidenceTier     String    @map("evidence_tier")
  /// Array of evidence items: { kind, sourceUrl, pageNumber?, quote? }.
  evidence         Json      @default("[]") @map("evidence_jsonb")
  /// 'accepted' | 'candidate' | 'quarantined' | 'rejected'. Default derived from
  /// score+tier per the plan thresholds (see deriveMatchStatus).
  status           String    @default("candidate") @db.VarChar(20)
  /// True when score < 0.50 — stored as a weak signal, NEVER surfaced.
  weakSignal       Boolean   @default(false) @map("weak_signal")
  matchBasis       String?   @map("match_basis") @db.Text
  resolvedByUserId String?   @map("resolved_by_user_id") @db.Uuid
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz(6)
  decisionNotes    String?   @map("decision_notes") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  // Unique on (peCode, coalesce(projectCode,''), programId): a project-null and a
  // project-scoped match to the same program coexist; two matches with the same
  // (pe, project, program) do not. Postgres treats NULLs as distinct, so the
  // coalesce()-based uniqueness is enforced via a raw expression index in the
  // migration (Prisma cannot express a functional unique index).
  @@index([programId], map: "pe_program_match_program_id_idx")
  @@index([peCode], map: "pe_program_match_pe_code_idx")
  @@index([status], map: "pe_program_match_status_idx")
  @@map("pe_program_match")
}

model PersonRole {
