  /// SAM.gov notice type (e.g. 'Solicitation', 'Combined Synopsis/Solicitation',
  /// 'Presolicitation', 'Sources Sought', 'Award Notice').
  noticeType          String    @map("notice_type") @db.VarChar(32)
  agency              String?
  office              String?
  /// Product/Service Code.
  pscCode             String?   @map("psc_code") @db.VarChar(8)
  naicsCode           String?   @map("naics_code") @db.VarChar(8)
  postedDate          DateTime? @map("posted_date") @db.Timestamptz(6)
  responseDeadline    DateTime? @map("response_deadline") @db.Timestamptz(6)
  archiveDate         DateTime? @map("archive_date") @db.Timestamptz(6)
  description         String?   @db.Text
  /// Primary point-of-contact name (public header field).
  pocName             String?   @map("poc_name")
  pocEmail            String?   @map("poc_email")
  placeOfPerformance  Json      @default("{}") @map("place_of_performance_jsonb")
  sourceUrl           String?   @map("source_url")
  /// Derived from archiveDate: false once the notice's archive date has passed.
  active              Boolean   @default(true)
  raw                 Json      @default("{}") @map("raw_jsonb")
  lastSyncedAt        DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  matches SamOpportunityMatch[]

  @@index([active, responseDeadline], map: "sam_opportunity_active_response_deadline_idx")
  @@index([naicsCode], map: "sam_opportunity_naics_code_idx")
  @@index([pscCode], map: "sam_opportunity_psc_code_idx")
  @@index([office], map: "sam_opportunity_office_idx")
  @@map("sam_opportunity")
}

model SamOpportunityMatch {
  id            String   @id @default(uuid()) @db.Uuid
  opportunityId String   @map("opportunity_id") @db.Uuid
  programId     String?  @map("program_id") @db.Uuid
  peCode        String?  @map("pe_code") @db.VarChar(16)
  /// 'program_alias' | 'office' | 'psc_naics_component' | 'description_pe_code'.
  matchBasis    String   @map("match_basis") @db.VarChar(24)
  confidence    Float    @default(0.5)
  /// 'candidate' | 'accepted' | 'quarantined' | 'rejected'. Default 'candidate';
  /// only 'description_pe_code' may be 'accepted'.
  reviewStatus  String   @default("candidate") @map("review_status") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  opportunity SamOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  program     Program?       @relation(fields: [programId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Unique on (opportunity_id, coalesce(program_id::text,''), coalesce(pe_code,'')) —
  // Postgres treats NULLs as distinct, so the coalesce()-based uniqueness is enforced
  // via a raw expression index in the migration (Prisma cannot express it).
  @@index([programId], map: "sam_opportunity_match_program_id_idx")
  @@index([peCode], map: "sam_opportunity_match_pe_code_idx")
  @@index([reviewStatus], map: "sam_opportunity_match_review_status_idx")
  @@map("sam_opportunity_match")
}

model SecFiling {
  id              String    @id @default(uuid())
  cik             String // Central Index Key (zero-padded 10 digits)
  companyName     String    @map("company_name")
  formType        String    @map("form_type") // 10-K, 10-Q, 8-K, DEF14A, S-1, etc.
  accessionNumber String    @unique @map("accession_number")
  filingDate      DateTime  @map("filing_date") @db.Date
  reportDate      DateTime? @map("report_date") @db.Date
  primaryDoc      String?   @map("primary_doc") // filename of the primary document
  description     String?   @db.Text
  sic             String? // Standard Industrial Classification code
  stateOfIncorp   String?   @map("state_of_incorp")
  fiscalYearEnd   String?   @map("fiscal_year_end") // MMDD format
  url             String?
  syncedAt        DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([cik])
  @@index([formType, filingDate])
  @@index([companyName])
  @@map("sec_filing")
}

model SourceDocument {
  id                     String    @id @default(uuid()) @db.Uuid
  // Stable human key, derived from the committed artifact filename (e.g. 'jbook_r1_fy2027').
  sourceKey              String    @map("source_key")
  fiscalYear             Int?      @map("fiscal_year")
  // pb | hasc | sasc | hac_d | sac_d | conference | enacted | supplemental
  budgetCycle            String    @map("budget_cycle")
  // ARMY | NAVY | AF | SF | DW | ... (null for the all-component R-1 master list / committee docs)
  component              String?
  // r1 | r2 | r3 | p1 | p40 | committee_report | conference_report | public_law | other
  documentType           String    @map("document_type")
  title                  String
  // Source PDF URL (J-books); the artifact's source filename when no URL exists (committee docs).
  sourceUrl              String    @map("source_url")
  sha256                 String?   @db.Char(64)
  byteSize               Int?      @map("byte_size")
  pageCount              Int?      @map("page_count")
  downloadedAt           DateTime? @map("downloaded_at") @db.Timestamptz(6)
  // Path under apps/api/scripts/__data__/ for the committed extraction artifact.
  artifactPath           String?   @map("artifact_path")
  // structured_import | deterministic_pdf | manual
  extractionMethod       String    @map("extraction_method")
  extractionToolVersion  String?   @map("extraction_tool_version")
  ingestedAt             DateTime  @default(now()) @map("ingested_at") @db.Timestamptz(6)
  // Version chain: set on the OLD head when a newer version of the same sourceKey is ingested.
  supersededByDocumentId String?   @map("superseded_by_document_id") @db.Uuid
  metadata               Json      @default("{}") @map("metadata_jsonb")

  supersededBy SourceDocument?  @relation("SourceDocumentVersion", fields: [supersededByDocumentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  supersedes   SourceDocument[] @relation("SourceDocumentVersion")

  programElementSources    ProgramElementSource[]
  programElementProjects   ProgramElementProject[]
  programElementPerformers ProgramElementPerformer[]
  yearSourceValues         ProgramElementYearSourceValue[]
  budgetPositions          ProgramElementBudgetPosition[]
  provisions               CommitteeReportProvision[]

  @@unique([sourceKey, sha256], map: "source_document_source_key_sha256_key")
  @@index([documentType, fiscalYear, budgetCycle, component], map: "source_document_type_fy_cycle_component_idx")
  @@index([sourceKey], map: "source_document_source_key_idx")
  @@map("source_document")
}

model StateBill {
  id               String    @id // openstates bill ID
  state            String // 2-letter state code
  session          String // legislative session
  identifier       String // e.g. "HB 1234"
  title            String    @db.Text
  chamber          String? // upper, lower
  classification   String[]  @default([]) // bill, resolution, etc.
  subjects         String[]  @default([])
  sponsorName      String?   @map("sponsor_name")
  sponsorParty     String?   @map("sponsor_party")
  latestActionDate DateTime? @map("latest_action_date") @db.Date
  latestActionText String?   @map("latest_action_text")
  url              String?
  syncedAt         DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([state, session])
  @@index([state, latestActionDate])
  @@map("state_bill")
}

model StateLegislator {
  id         String   @id // openstates person ID
  name       String
  state      String
  chamber    String? // upper, lower
  district   String?
  party      String?
  email      String?
  image      String?
  url        String?
  committees Json     @default("[]") // [{name, role}]
  active     Boolean  @default(true)
  syncedAt   DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([state, chamber])
  @@index([party, state])
  @@map("state_legislator")
}

model SyncRun {
  id           String    @id @default(uuid()) @db.Uuid
  source       String
  startedAt    DateTime  @map("started_at") @db.Timestamptz(6)
  finishedAt   DateTime? @map("finished_at") @db.Timestamptz(6)
  rowsInserted Int       @default(0) @map("rows_inserted")
  rowsUpdated  Int       @default(0) @map("rows_updated")
  errorCount   Int       @default(0) @map("error_count")
  status       String    @default("running")
  errorMessage String?   @map("error_message")

  @@index([source, startedAt(sort: Desc)], map: "sync_run_source_started_at_idx")
  @@map("sync_run")
}

model WorkflowTemplate {
  id               String   @id @default(uuid()) @db.Uuid
  slug             String   @unique
  name             String
  description      String?  @db.Text
  category         String   @default("authorization")
  requiredSections Json     @default("[]") @map("required_sections_jsonb")
  contextInfo      Json     @default("{}") @map("context_info_jsonb")
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)


  @@map("workflow_templates")
}
